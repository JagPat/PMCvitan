# apps/api environment (Phase 7). Copy to .env and fill in.
DATABASE_URL="postgresql://vitan:vitan@localhost:5432/vitan_pmc?schema=public"

# Auth
# JWT_SECRET is REQUIRED in production — the API refuses to start without it (no
# insecure default). Use a long random value. Outside production a dev default is
# used if unset.
JWT_SECRET="change-me"
JWT_REFRESH_SECRET="change-me-too"
# CORS allowlist — comma-separated origins allowed to call the API from a browser.
# REQUIRED in production (the API refuses to start if unset; no wildcard). Any
# origin is allowed in dev when this is unset.
CORS_ORIGINS="https://pms.vitan.in"
# Passwordless dev auth ("Viewing as" persona switch). SECURE BY DEFAULT: dev
# auth is OFF unless this is exactly "true". Set "true" only for the demo (lets
# POST /auth/session mint a scoped token per persona). Unset/anything-else = real
# login only (email+password / phone OTP / email OTP / Google / worker token).
# The web app has a matching build-time flag: VITE_ALLOW_DEV_AUTH.
ALLOW_DEV_AUTH="true"
# Password for the seeded demo accounts (pmc/client/contractor @vitan.in).
SEED_DEMO_PASSWORD="vitan123"
# Self-signup for the office channels (email OTP / Google). SECURE BY DEFAULT:
# invite-only — an unknown email/Google identity is rejected ("ask your PMC to
# add you"), so a stranger can't mint a writable engineer account. Set "true" to
# let unknown email/Google sign-ins auto-provision an engineer.
AUTH_ALLOW_SIGNUP="false"
# Self-signup for PHONE OTP: an unknown number auto-provisions a site engineer.
# DEFAULT OFF IN PRODUCTION (unknown numbers are rejected) so a stranger's phone
# can't mint a writable engineer account; set "true" to enable on-site onboarding.
# Outside production it defaults on (unset) so the local demo's phone flow works.
AUTH_ALLOW_PHONE_SIGNUP="false"

# Worker device tokens (QR job-card onboarding at POST /auth/worker/token). When set, the
# site QR must carry this secret (`enrollSecret`) or minting is refused — locks the endpoint
# down in production. Leave UNSET in dev/demo so QR onboarding stays frictionless. The
# endpoint is rate-limited and rejects unknown/archived projects regardless of this setting.
WORKER_ENROLL_SECRET=""

# Phone OTP — channel priority: MSG91 > Fast2SMS > Telegram > dev-stub. First configured wins.
#
# 1) MSG91 (India SMS). Both AUTH_KEY + TEMPLATE_ID required; needs DLT.
MSG91_AUTH_KEY=""
MSG91_TEMPLATE_ID=""
MSG91_SENDER_ID=""
# 2) Fast2SMS (India). Set the Dev API key: fast2sms.com → add credit → Dev API.
#    - FAST2SMS_OTP_ID set → Smart OTP (/dev/otp/send): delivers via a linked
#      template over WhatsApp and/or SMS (no DLT; assign the template in Smart OTP).
#    - unset → older bulkV2 `otp` route (SMS only; needs OTP-route verification).
FAST2SMS_API_KEY=""
FAST2SMS_OTP_ID=""
# 3) Telegram Gateway — zero-DLT, free, but only reaches users who have Telegram
#    (and a free account only texts its own number). gatewayapi.telegram.org.
TELEGRAM_GATEWAY_TOKEN=""

# Email OTP (zero-DLT fallback). Blank = dev stub (code logged + returned).
# Set SMTP to send real emails (e.g. Zoho: smtp.zoho.in:465 secure).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Vitan PMC <no-reply@vitan.in>"

# Google sign-in. Set the OAuth Web client ID to enable (POST /auth/google
# verifies ID tokens against it); blank = the endpoint reports it's disabled.
GOOGLE_CLIENT_ID=""

# Object storage for site photos (S3-compatible, e.g. Cloudflare R2).
# Leave blank to run the dev stub (bytes kept in Postgres, served from
# GET /media/:id). Set all four to store in the bucket instead — no code change.
S3_ENDPOINT=""
S3_BUCKET="vitan-media"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION="auto"
# Public base for object URLs; defaults to <S3_ENDPOINT>/<S3_BUCKET> if unset.
S3_PUBLIC_BASE=""

# Web Push (VAPID). Generate a keypair once: `npx web-push generate-vapid-keys`.
# Leave blank to disable push (subscriptions are still stored; sends are no-ops).
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@vitan.in"

PORT=3000
