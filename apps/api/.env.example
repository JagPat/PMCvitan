# apps/api environment (Phase 7). Copy to .env and fill in.
DATABASE_URL="postgresql://vitan:vitan@localhost:5432/vitan_pmc?schema=public"

# Auth
JWT_SECRET="change-me"
JWT_REFRESH_SECRET="change-me-too"
# Passwordless dev auth ("Viewing as" persona switch). Set to "false" in prod to
# require real login (email+password / phone OTP / worker token). Default: enabled.
ALLOW_DEV_AUTH="true"
# Password for the seeded demo accounts (pmc/client/contractor @vitan.in).
SEED_DEMO_PASSWORD="vitan123"

# Phone OTP via MSG91 (India). Leave AUTH_KEY/TEMPLATE_ID blank to run the
# in-memory dev stub (the server logs the code and returns it to the caller).
# Set both to go live against a DLT-approved template (its ##OTP## variable).
MSG91_AUTH_KEY=""
MSG91_TEMPLATE_ID=""
MSG91_SENDER_ID=""

# Object storage (S3-compatible, e.g. Cloudflare R2)
S3_ENDPOINT=""
S3_BUCKET="vitan-media"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

PORT=3000
