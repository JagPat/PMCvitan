{
  "name": "api",
  "private": true,
  "version": "0.0.0",
  "description": "Vitan PMC backend — NestJS + Prisma REST API.",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "seed": "tsx prisma/seed.ts",
    "ensure-accounts": "tsx prisma/ensure-accounts.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "outbox:status": "tsx src/platform/outbox/outbox.cli.ts status",
    "outbox:retry": "tsx src/platform/outbox/outbox.cli.ts retry",
    "outbox:seal-external": "tsx src/platform/outbox/outbox.cli.ts seal-external",
    "projection:rebuild": "tsx src/platform/projections/projection-rebuild.cli.ts",
    "capability:enable": "tsx src/platform/capability.cli.ts",
    "t45:preflight": "tsx src/platform/t45/t45.cli.ts preflight",
    "t45:migration-state": "tsx src/platform/t45/t45.cli.ts migration-state",
    "t45:repair": "tsx src/platform/t45/t45.cli.ts repair"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@vitan/shared": "workspace:*",
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1081.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.1.27",
    "@nestjs/websockets": "^11.1.27",
    "@prisma/client": "^6.3.0",
    "bcryptjs": "^3.0.3",
    "google-auth-library": "^10.9.0",
    "nodemailer": "^9.0.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.28",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^7.2.0",
    "@types/web-push": "^3.6.4",
    "prisma": "^6.3.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "~5.7.3",
    "vitest": "^4.0.0"
  }
}
