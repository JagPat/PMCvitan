// Vitan PMC — database schema (PostgreSQL via Prisma).
// Phase-7 Slice 1: the entities behind the project snapshot and the core
// mutations. Fields are aligned with the frontend domain model
// (apps/web / packages/shared) so the API returns shapes the client uses
// directly. Phase 7c-auth adds User (accounts + phone identity) and
// WorkerDevice (no-account device tokens). Media and offline-outbox tables
// arrive in later slices. See docs/DATA_MODEL.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DecisionStatus {
  pending
  approved
  change
}

enum ActivityStatus {
  not_started
  in_progress
  done
  blocked
}

enum GateState {
  ok
  wait
  fail
  na
}

enum InspectionResult {
  PASS
  FAIL
}

model Project {
  id           String   @id
  name         String
  short        String
  descriptor   String
  stage        String
  siteCode     String
  projStart    String
  projEnd      String
  elapsedPct   Int
  todayDay     Int
  milestonePct Int
  createdAt    DateTime @default(now())

  decisions     Decision[]
  activities    Activity[]
  inspections   Inspection[]
  dailyLogs     DailyLog[]
  notifications Notification[]
  users         User[]
  workerDevices WorkerDevice[]
  media         Media[]
  pushSubs      PushSubscription[]
  drawings      Drawing[]
  phases        Phase[]
  org           Org?           @relation(fields: [orgId], references: [id])
  orgId         String?
  memberships   Membership[]
}

// An Org/Account (an architecture practice, e.g. "Vitan Architecture") — owns
// projects and the people who administer them. Multi-tenant foundation.
model Org {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique
  createdAt DateTime        @default(now())
  projects  Project[]
  members   OrgMembership[]
}

// Who can administer an org: owner/admin create projects + manage teams; member
// is a plain participant. Distinct from a project role (pmc/client/…).
model OrgMembership {
  id        String   @id @default(cuid())
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      String // owner | admin | member
  createdAt DateTime @default(now())

  @@unique([orgId, userId])
  @@index([userId])
}

// A user's access to a specific project, with the role they hold there. A user
// can have memberships on several projects (different roles on each). This is the
// grant the app scopes tokens to; the legacy User.projectId/role is the default.
model Membership {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      String // pmc | client | engineer | contractor
  status    String   @default("active") // invited | active | removed
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
  @@index([userId])
}

// A browser Web Push subscription (Phase 8). Endpoint is unique per device;
// notifications for a project fan out to all its subscriptions. When no VAPID
// keys are configured the send path is a no-op (dev stub).
model PushSubscription {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id])
  projectId String
  endpoint  String   @unique
  p256dh    String
  auth      String
  role      String?
  createdAt DateTime @default(now())
}

// An uploaded site photo (geo + timestamp, zoomable on the client). Phase
// 7c-media. Storage is provider-agnostic: with S3/R2 configured the bytes live
// in the bucket and `url` points at them; with no provider the bytes are kept
// in `data` (dev stub) and served from GET /media/:id. `decisionId`/`dailyLogId`
// are loose links to what the photo documents.
model Media {
  id         String   @id @default(cuid())
  project    Project  @relation(fields: [projectId], references: [id])
  projectId  String
  kind       String // progress | inspection | decision | attendance | material
  mime       String
  data       Bytes? // dev stub: bytes in the DB; null once stored in S3/R2
  url        String? // set in S3/R2 mode; null for the dev stub
  storageKey String?
  sizeBytes  Int      @default(0)
  geoLat     Float?
  geoLng     Float?
  takenAt    String? // display timestamp, e.g. "03 Jul 2026 · 9:12 AM"
  uploadedBy String
  decisionId String?
  dailyLogId String?
  createdAt  DateTime @default(now())

  @@index([projectId, kind])
}

// A controlled drawing in the project's register (the source of truth the team
// builds from). Identified by its number within the project; each issue is a
// DrawingRevision, the latest non-superseded one being "current". Files are held
// by StorageService (S3/R2 or the DB dev stub), same as Media. Slice 1.
model Drawing {
  id         String            @id @default(cuid())
  project    Project           @relation(fields: [projectId], references: [id])
  projectId  String
  number     String // e.g. "A-201"
  title      String
  discipline String // architectural | structural | mep | other
  zone       String?
  activityId String? // the work this drawing governs (Slice 2 linkage)
  decisionId String?
  createdAt  DateTime          @default(now())
  revisions  DrawingRevision[]

  @@unique([projectId, number])
  @@index([projectId])
}

// One issued revision of a drawing (Rev A, B, C…). Issuing a new rev supersedes
// the prior ones so the field only ever builds from `for_construction` current.
model DrawingRevision {
  id         String   @id @default(cuid())
  drawing    Drawing  @relation(fields: [drawingId], references: [id], onDelete: Cascade)
  drawingId  String
  rev        String // "A" | "B" | "C" …
  status     String // for_review | for_construction | superseded
  mime       String
  data       Bytes? // dev stub: bytes in the DB; null once stored in S3/R2
  url        String? // set in S3/R2 mode; null for the dev stub
  storageKey String?
  sizeBytes  Int      @default(0)
  note       String   @default("")
  issuedBy   String
  issuedAt   String // display timestamp, e.g. "08 Jul 2026"
  createdAt  DateTime @default(now())
  acks       DrawingAck[]

  @@index([drawingId])
}

// A build-acknowledgement: a contractor / engineer confirming they are building
// to a specific revision ("building to Rev C"). Per-revision, so a superseding
// issue starts a fresh round of acks — the PMC can see who is on the current set.
model DrawingAck {
  id         String          @id @default(cuid())
  revision   DrawingRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  revisionId String
  userId     String
  userName   String
  role       String
  at         DateTime        @default(now())

  @@unique([revisionId, userId])
  @@index([revisionId])
}

// A real account: PMC / client / contractor sign in with email + password;
// site engineers are provisioned on first successful phone OTP. Passwordless
// dev auth (the "Viewing as" persona switch) is separate and gated by
// ALLOW_DEV_AUTH. Phase 7c-auth.
model User {
  id           String   @id @default(cuid())
  project      Project  @relation(fields: [projectId], references: [id])
  projectId    String
  role         String // pmc | client | engineer | contractor
  name         String
  email        String?  @unique
  phone        String?  @unique
  passwordHash String?
  createdAt    DateTime @default(now())

  orgMemberships OrgMembership[]
  memberships    Membership[]
}

// A worker's device identity (QR / tap-photo job card) — no account, no
// password. Each tap mints a short-lived scoped token recorded here for
// attribution. Phase 7c-auth.
model WorkerDevice {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id])
  projectId String
  name      String?
  trade     String?
  token     String   @unique
  createdAt DateTime @default(now())
  lastSeen  DateTime @default(now())
}

model Decision {
  id             String           @id // e.g. "DL-014"
  project        Project          @relation(fields: [projectId], references: [id])
  projectId      String
  title          String
  room           String
  status         DecisionStatus   @default(pending)
  ageDays        Int?
  photoSwatch    String
  approvedOption String?
  material       String?
  approver       String?
  date           String? // display date, e.g. "12 Jun 2026"
  cost           Int? // rupees
  createdAt      DateTime         @default(now())

  options        DecisionOption[]
  events         DecisionEvent[]
  changeRequests ChangeRequest[]
  activities     Activity[]
  materials      SiteMaterial[]
}

model DecisionOption {
  id          String   @id @default(cuid())
  decision    Decision @relation(fields: [decisionId], references: [id])
  decisionId  String
  label       String
  optionKey   String
  material    String
  delta       Int // rupees
  swatch      String
  recommended Boolean  @default(false)
  order       Int      @default(0)
}

// Append-only lifecycle + audit log for a decision.
model DecisionEvent {
  id         String   @id @default(cuid())
  decision   Decision @relation(fields: [decisionId], references: [id])
  decisionId String
  type       String // issued | approved | locked | change_requested
  actor      String
  at         DateTime @default(now())
  payload    Json?
}

model ChangeRequest {
  id             String   @id @default(cuid())
  decision       Decision @relation(fields: [decisionId], references: [id])
  decisionId     String
  reason         String
  costImpact     Int // rupees
  timeImpactDays Int
  status         String   @default("pending")
  createdAt      DateTime @default(now())
}

model Activity {
  id             String         @id // e.g. "ACT-31"
  project        Project        @relation(fields: [projectId], references: [id])
  projectId      String
  name           String
  zone           String
  status         ActivityStatus @default(not_started)
  // planned/actual as day-offsets from 1 Jun 2026 (frontend timeline model)
  plannedStart   Int
  plannedEnd     Int
  actualStart    Int?
  actualEnd      Int?
  block          String?
  // stored readiness gates; the Decision gate is derived live from the decision
  gateMaterial   GateState @default(na)
  gateTeam       GateState @default(na)
  gateInspection GateState @default(na)
  decision       Decision?      @relation(fields: [decisionId], references: [id])
  decisionId     String?
  phase          Phase?         @relation(fields: [phaseId], references: [id])
  phaseId        String?
  order          Int            @default(0)

  @@unique([projectId, id])
}

// A project phase (Foundation → Structure → MEP → Finishing…). Groups activities
// for phase-level monitoring; planned window as day-offsets (like activities).
model Phase {
  id           String     @id @default(cuid())
  project      Project    @relation(fields: [projectId], references: [id])
  projectId    String
  name         String
  order        Int        @default(0)
  plannedStart Int        @default(0)
  plannedEnd   Int        @default(0)
  activities   Activity[]

  @@index([projectId])
}

model Inspection {
  id        String           @id // e.g. "INSP-22"
  project   Project          @relation(fields: [projectId], references: [id])
  projectId String
  kind      String // "checklist" (engineer draft) | "review" (submitted to PMC)
  title     String
  zone      String
  by        String?
  date      String
  submitted Boolean          @default(false)
  decided   Boolean          @default(false)
  items     InspectionItem[]
}

model InspectionItem {
  id           String            @id @default(cuid())
  inspection   Inspection        @relation(fields: [inspectionId], references: [id])
  inspectionId String
  name         String
  order        Int               @default(0)
  // checklist fields
  state        String? // pass | fail | na
  photos       Int               @default(0)
  note         String            @default("")
  // review fields
  result       InspectionResult?
  swatch       String?
  rejected     Boolean           @default(false)
}

model DailyLog {
  id          String         @id @default(cuid())
  project     Project        @relation(fields: [projectId], references: [id])
  projectId   String
  date        String
  checkedIn   Boolean        @default(false)
  checkinTime String?
  submitted   Boolean        @default(false)
  progress    Int            @default(0)
  crew        CrewRow[]
  materials   SiteMaterial[]
}

model CrewRow {
  id         String   @id @default(cuid())
  dailyLog   DailyLog @relation(fields: [dailyLogId], references: [id])
  dailyLogId String
  trade      String
  count      Int      @default(0)
  order      Int      @default(0)
}

model SiteMaterial {
  id         String    @id @default(cuid())
  dailyLog   DailyLog  @relation(fields: [dailyLogId], references: [id])
  dailyLogId String
  decision   Decision? @relation(fields: [decisionId], references: [id])
  decisionId String?
  name       String
  qty        String
  zone       String
  matched    Boolean   @default(true)
  swatch     String
  photo      Boolean   @default(false)
  order      Int       @default(0)
}

model Notification {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id])
  projectId String
  text      String
  color     String
  time      String // relative label, e.g. "2h ago" / "just now"
  at        DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  projectId String?
  actor     String
  action    String
  entity    String
  entityId  String
  at        DateTime @default(now())
  payload   Json?
}
