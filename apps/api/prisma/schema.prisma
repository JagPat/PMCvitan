// Vitan PMC — database schema (PostgreSQL via Prisma).
// Phase-7 Slice 1: the entities behind the project snapshot and the core
// mutations. Fields are aligned with the frontend domain model
// (apps/web / packages/shared) so the API returns shapes the client uses
// directly. Phase 7c-auth adds User (accounts + phone identity) and
// WorkerDevice (no-account device tokens). Media and offline-outbox tables
// arrive in later slices. See docs/DATA_MODEL.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DecisionStatus {
  pending
  approved
  change
}

enum ActivityStatus {
  not_started
  in_progress
  // Phase 1 Task 5: an engineer's completion CLAIM parks the activity here;
  // only the PMC's approval of the linked closing inspection writes `done`
  awaiting_signoff
  done
  blocked
}

enum GateState {
  ok
  wait
  fail
  na
}

enum InspectionResult {
  PASS
  FAIL
}

model Project {
  id           String   @id
  name         String
  short        String
  descriptor   String
  stage        String
  siteCode     String
  location     String   @default("") // site address / locality (free text)
  projStart    String
  projEnd      String
  // Real civil dates (Phase 0 Task 6). scheduleStartDate is the SCHEDULE ANCHOR —
  // the calendar day legacy day-offset 0 refers to (proven by characterization:
  // dayLabel(0) === '1 Jun'); display projStart/projEnd stay as legacy strings.
  scheduleStartDate DateTime? @db.Date
  scheduleEndDate   DateTime? @db.Date
  timeZone          String    @default("Asia/Kolkata")
  elapsedPct   Int
  todayDay     Int
  milestonePct Int
  createdAt    DateTime @default(now())
  archivedAt   DateTime? // soft-delete: hidden from listings/switcher/portfolio when set

  decisions     Decision[]
  activities    Activity[]
  inspections   Inspection[]
  dailyLogs     DailyLog[]
  notifications Notification[]
  users         User[]
  workerDevices WorkerDevice[]
  media         Media[]
  pushSubs      PushSubscription[]
  drawings      Drawing[]
  phases        Phase[]
  gateOverrides GateOverride[]
  // Tenant — NON-NULL since Phase 2 Task 4 (the event envelope's composite tenant key
  // (organizationId, projectId) references Project(orgId, id); a project cannot exist
  // without an org). Legacy null-org projects are backfilled by the migration's diagnostic,
  // which ABORTS rather than guess a tenant. @@unique([orgId, id]) is added in raw SQL.
  org           Org            @relation(fields: [orgId], references: [id])
  orgId         String
  memberships   Membership[]
  companies     ProjectCompany[]
  nodes         ProjectNode[]
  siteMaterials SiteMaterial[]
  eventStream   ProjectEventStream?
  domainEvents  DomainEvent[]

  // Composite identity the DomainEvent tenant FK references (Phase 2 Task 4) — proves an
  // event's (organizationId, projectId) is the project's REAL org, so org cannot be forged.
  @@unique([orgId, id])
}

// Phase 2 Task 4 — the per-project event stream counter. Exactly one row per project
// (created inside the project-creation transaction; backfilled for legacy projects).
// `emit()` locks this row (SELECT … FOR UPDATE via an atomic increment) and assigns the
// gap-safe `streamPosition` INSIDE the owning mutation transaction, so two concurrent
// commits on one project can never collide or skip a position.
model ProjectEventStream {
  projectId    String  @id
  nextPosition BigInt  @default(0)
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// Phase 2 Task 4 — the append-only domain-event store. Ordering is (projectId, streamPosition),
// NEVER occurredAt (display/audit only). The composite tenant FK (organizationId, projectId) ->
// Project(orgId, id), the attribution truth-table CHECK, and the BEFORE UPDATE OR DELETE
// append-only trigger are all added in raw SQL by 20261015000000_phase2_event_envelope
// (Prisma cannot express them). See packages/shared/src/platform/events.ts for the envelope.
model DomainEvent {
  eventId         String   @id @default(uuid())
  eventType       String
  payloadVersion  Int      @default(1)
  organizationId  String
  projectId       String
  streamPosition  BigInt
  siteId          String?
  actorId         String?
  actorKind       String // 'human' | 'system'
  systemActor     String? // NON-NULL iff actorKind='system' (a named constant system actor)
  entityType      String
  entityId        String
  occurredAt      DateTime @default(now()) // DISPLAY/AUDIT ONLY — never an ordering key
  correlationId   String?
  causedByEventId String?
  payload         Json?
  // Phase 2 fix-forward PR B — immutable dispatch metadata recorded at commit time: what external
  // consequences (socket invalidate / push body+roles) the command requested. NOT a projection
  // result and NEVER mutated after insert. NULL = a pre-intent legacy event (the scanner treats it
  // as an external no-op; it never invents a historical push). PR C supplies the final per-command
  // catalog; PR B persists a compatibility intent (effectKey 'compat.task6').
  dispatchIntent  Json?
  // Composite tenant FK → Project(orgId, id): a forged organizationId (not the project's own
  // org) is rejected by the DB. RESTRICT — an append-only event outlives soft-deletes.
  tenant          Project  @relation(fields: [organizationId, projectId], references: [orgId, id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([projectId, streamPosition])
  // Candidate key the OutboxDelivery composite FK references (PR B) — a delivery's copied
  // (projectId, streamPosition) can no longer disagree with its event's real coordinates.
  @@unique([eventId, projectId, streamPosition])
  @@index([projectId, streamPosition])
  @@index([eventType])
  deliveries      OutboxDelivery[]
}

// Phase 2 Task 6 — the per-consumer transactional outbox. For each DomainEvent, one
// OutboxDelivery row per registered consumer is written IN THE SAME mutation transaction, so a
// crash can never leave an event with no durable delivery work. A lease-based relay claims
// pending rows (a SHORT lease transaction — never a lock held across dispatch), dispatches to the
// consumer, and moves the row pending→leased→succeeded, or on a retryable failure clears the
// lease + backs off (attempts++, nextAttemptAt) back to pending, or on exhaustion → dead. There
// is NO ambiguous 'failed'. Contract: at-least-once delivery, effectively-once DB effects.
model OutboxDelivery {
  id             String      @id @default(uuid())
  // PR B — the composite FK binds the copied (projectId, streamPosition) to the event's REAL
  // coordinates, so a forged/mismatched delivery coordinate is rejected by PostgreSQL. Replaces
  // the Task-6 event-only FK. Cascade delete only ever fires for a disposable TRUNCATE reset.
  event          DomainEvent @relation(fields: [eventId, projectId, streamPosition], references: [eventId, projectId, streamPosition], onDelete: Cascade, onUpdate: Cascade)
  eventId        String
  projectId      String
  consumer       String
  consumerKind   String // 'ordered' | 'unordered'
  // PR B — every registered consumer gets a row for every event: 'dispatch' invokes the consumer,
  // 'noop' records the event was deliberately irrelevant (so an ordered cursor never waits behind
  // a stream position for which no row exists). Closed set; no inferred representation.
  deliveryAction String    @default("dispatch") // 'dispatch' | 'noop'
  streamPosition BigInt // copied from the event; ordered consumers checkpoint on it
  status         String    @default("pending") // 'pending' | 'leased' | 'succeeded' | 'dead'
  attempts       Int       @default(0)
  nextAttemptAt  DateTime  @default(now())
  leaseOwner     String?
  leaseExpiresAt DateTime?
  lastError      String?
  payload        Json? // consumer-specific dispatch data (e.g. Web Push {body, roles})
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  // PR B — a restrictive composite FK to the durable consumer catalog: a delivery's
  // (consumer, consumerKind) must name a declared catalog contract, and a catalog row that still
  // has deliveries cannot be deleted (Restrict). Deactivation stops new obligations, never deletes.
  catalog        OutboxConsumerCatalog @relation(fields: [consumer, consumerKind], references: [consumer, consumerKind], onDelete: Restrict, onUpdate: Cascade)

  @@unique([eventId, consumer]) // exactly one delivery row per (event, consumer)
  @@index([consumer, status, nextAttemptAt]) // the relay's claim scan
  @@index([consumer, projectId, streamPosition]) // an ordered consumer's per-project stream
}

// Phase 2 fix-forward PR B — the DURABLE consumer catalog. The relational pair
// (active OutboxConsumerCatalog row × DomainEvent row) is the obligation: exactly one
// OutboxDelivery must exist for it. This survives a process crash / rolling deploy without mutating
// the append-only DomainEvent — the scanner derives missing deliveries from this catalog. A changed
// kind/effect/version is a startup error requiring an explicit migration (never a silent reinterpret).
model OutboxConsumerCatalog {
  consumer       String   @id
  consumerKind   String // 'ordered' | 'unordered'
  consumerEffect String // 'db' | 'external'
  catalogVersion Int // the consumer CONTRACT version, not an app release
  active         Boolean  @default(true)
  registeredAt   DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deliveries     OutboxDelivery[]

  @@unique([consumer, consumerKind]) // the composite the OutboxDelivery FK references
}

// Phase 2 fix-forward PR B — a durable audit row for every operator dead-letter action
// (retry/redrive). Written IN THE SAME transaction as the action it records. Never stores event
// payloads or secrets.
model OutboxOperatorAction {
  id               String   @id @default(uuid())
  action           String // e.g. 'retry'
  deliveryId       String?
  consumer         String?
  projectId        String?
  eventId          String?
  operatorIdentity String
  reason           String
  priorError       String?
  at               DateTime @default(now())

  @@index([at])
}

// Phase 2 fix-forward PR B — declared now, sealed in PR C. A singleton row (CHECK key='singleton')
// records the external-effect coverage version that outbox-mode startup must match. PR B only
// declares the table; the audited seal transaction and the null-intent rejection trigger land in PR C.
model OutboxCutoverState {
  key             String   @id // singleton — CHECK (key = 'singleton')
  coverageVersion String
  sealedAt        DateTime @default(now())
  sealedBy        String
  reason          String
  updatedAt       DateTime @updatedAt
}

// Phase 2 Task 6 — a database consumer records one ProcessedEvent per (consumer, eventId) IN THE
// SAME transaction as its side effect (effectively-once). A duplicate dispatch finds the row and
// skips re-applying. External consumers (socket/push) are at-least-once and do not use this.
model ProcessedEvent {
  id          String   @id @default(uuid())
  consumer    String
  eventId     String
  processedAt DateTime @default(now())

  @@unique([consumer, eventId])
}

// Phase 2 Task 6 — an ordered (per-project) consumer advances this cursor CONTIGUOUSLY: it may
// not apply streamPosition N+1 before N. A slow/failed earlier position holds the cursor; a
// `dead` earlier position sets status='blocked' and the projection is visibly degraded until an
// operator resolves it — never a silent skip. `appliedPosition` NULL = nothing applied yet (next
// expected = 0); otherwise the next expected position is appliedPosition + 1.
model ProjectionCursor {
  id              String   @id @default(uuid())
  consumer        String
  projectId       String
  appliedPosition BigInt? // NULL = none applied yet
  status          String   @default("live") // 'live' | 'blocked'
  updatedAt       DateTime @updatedAt

  @@unique([consumer, projectId])
}

// Phase 2 Task 9 — a projection GENERATION: the rebuildable read-model instance a projection
// consumer serves + advances. Each (consumer, projectId) has a monotone series of generations;
// exactly ONE is 'active' at a time (a raw-SQL PARTIAL unique index — Prisma cannot express WHERE
// — enforces `one active per (consumer, projectId)`, added in 20261101000000_phase2_projection_generations).
//
// The live relay applies each ordered `db` projection delivery into the ACTIVE generation,
// advancing `appliedPosition` CONTIGUOUSLY (position N+1 waits for N; a `dead` earlier position
// sets cursorStatus='blocked' — visible degradation, never a silent skip). An ONLINE REBUILD
// builds a NEW 'building' generation from a consistent canonical snapshot + event replay, then a
// final ACTIVATION BARRIER (per project: hold the ProjectEventStream lock, read the final position
// H, apply through H, then atomically activate the new generation with appliedPosition=H and retire
// the old one before releasing the lock) hands over with zero gap — every event allocated afterward
// is > H and targets the new generation, so nothing commits into the retired one.
//
// Dedup is per generation on `(consumer, generation, streamPosition)`: within one generation
// `appliedPosition` is the contiguous high-water mark, and a generation has a SINGLE writer at any
// instant (the rebuilder while 'building', the relay once 'active' — the barrier hands off in one
// transaction), so an event applied by both the relay and a rebuild replay is idempotent (the later
// apply sees position ≤ appliedPosition and skips). Projection ROWS carry this `generation`'s id, so
// a building generation is invisible to serving until it is activated and a retired one is dropped.
model ProjectionGeneration {
  id              String    @id @default(uuid())
  consumer        String
  projectId       String
  generation      Int // monotone per (consumer, projectId); the highest is the newest
  status          String    @default("building") // 'building' | 'active' | 'retired'
  appliedPosition BigInt? // contiguous checkpoint INTO THIS generation (NULL = none applied yet)
  cursorStatus    String    @default("live") // 'live' | 'blocked' (a dead earlier position blocks)
  activatedAt     DateTime? // when this generation became 'active' (the barrier commit)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([consumer, projectId, generation])
  @@index([consumer, projectId, status])
}

// Phase 2 Task 9 — the DECISIONS read-model projection (the first module's rebuildable read path).
// One row per (generation, decision): the decisions module's `decisions.inbox` projection consumer
// refreshes it from the canonical Decision on every decision.* event, storing the SAME serialized
// DecisionDto the live snapshot produces (via decision-serialize.ts) plus the columns the query
// filters on. Generation-scoped: `generationId` names the ProjectionGeneration the row belongs to
// (a plain column, not an FK — the generation lifecycle is managed by the rebuilder + the consumer's
// dropGeneration hook, mirroring ProcessedEvent/ProjectionCursor), so a building generation is
// invisible to serving until activated and a retired one is dropped wholesale. The read query serves
// the ACTIVE generation's rows and applies the per-viewer authz filter at query time (a projection is
// never an RBAC bypass) — `status`/`publishedAt`/`authorId` are duplicated out of `dto` as the filter
// keys, and `dto` is the pre-serialized DecisionDto.
model DecisionProjection {
  id           String    @id @default(uuid())
  generationId String
  projectId    String
  decisionId   String
  status       String // 'pending' | 'approved' | 'change' — the readiness map + the pending filter
  publishedAt  DateTime? // NULL = a private DRAFT (author-only visibility)
  authorId     String? // the draft author (author-private visibility)
  dto          Json // the serialized DecisionDto (options + open changeRequest inlined), unfiltered
  updatedAt    DateTime  @updatedAt

  @@unique([generationId, decisionId])
  @@index([generationId, projectId])
}

// Phase 2 Task 10 — the DAILY-LOG read-model projection (the daily-log module's rebuildable read
// path). Unlike DecisionProjection (one row per decision), the daily-log slice is a per-PROJECT
// composite — the latest log core (crew + its own materials) plus every project material — so a
// generation holds exactly ONE row per project, keyed (generationId, projectId), storing the whole
// serialized slice `computeDailyLogSlice` produces. The `daily-log.inbox` projection consumer
// refreshes it from canonical state on every dailylog.*/material.* event. Generation-scoped:
// `generationId` names the ProjectionGeneration the row belongs to (a plain column, not an FK — the
// lifecycle is managed by the rebuilder + the consumer's dropGeneration hook). The slice carries NO
// per-viewer visibility (every project viewer sees the same daily-log), so the read query serves the
// ACTIVE generation's row with no query-time filter.
model DailyLogProjection {
  id           String   @id @default(uuid())
  generationId String
  projectId    String
  dto          Json // the serialized DailyLogSlice: { dailyLog: DailyLogCore | null, materials: SiteMaterial[] }
  updatedAt    DateTime @updatedAt

  @@unique([generationId, projectId])
}

// Phase 2 Task 10 — the DRAWINGS read-model projection (the drawings module's rebuildable read path).
// Like DailyLogProjection (one row per project, not per entity), the drawings register is a per-PROJECT
// composite — every drawing with its revision history + governing-revision distribution facts — so a
// generation holds exactly ONE row per project, keyed (generationId, projectId), storing the whole
// serialized VIEWER-INDEPENDENT base `computeDrawingsBase` produces (drawings-serialize.ts). The
// `drawings.inbox` projection consumer refreshes it from canonical state on every drawing.* event. The
// per-viewer fields (draft-author visibility, the viewer's ack/recipient state) and each revision's
// short-lived signed `url` are baked at READ time — the base is neither per-viewer nor time-limited, so
// the stored row is safe to reuse across viewers and never holds an expiring token. Generation-scoped:
// `generationId` names the ProjectionGeneration the row belongs to (a plain column, not an FK — the
// lifecycle is managed by the rebuilder + the consumer's dropGeneration hook).
model DrawingsProjection {
  id           String   @id @default(uuid())
  generationId String
  projectId    String
  dto          Json // the serialized DrawingsBase (viewer-independent register; url + viewer fields baked at read)
  updatedAt    DateTime @updatedAt

  @@unique([generationId, projectId])
}

model InspectionsProjection {
  id           String   @id @default(uuid())
  generationId String
  projectId    String
  dto          Json // the serialized InspectionsBase (viewer-independent; role gating + signed evidence baked at read)
  updatedAt    DateTime @updatedAt

  @@unique([generationId, projectId])
}

// Phase 2 Task 5 — the command-idempotency ledger. One receipt per (scope, actor, commandType,
// idempotencyKey): a retried/duplicated command (offline replay, network retry, double-tap)
// reserves→executes→commits its succeeded receipt in ONE transaction, so the effect happens
// exactly once and a replay returns the stored result. Ordering/collision is enforced by
// SCOPE-SPECIFIC PARTIAL unique indexes (raw SQL — Prisma cannot express WHERE): project-scoped
// rows key on (projectId, actorId, commandType, idempotencyKey), org-scoped rows on
// (organizationId, …), so an org index never constrains a project row. The scope truth-table
// CHECK, the status CHECK and the composite project-scoped tenant FK (organizationId, projectId)
// -> Project(orgId, id) are raw SQL too (20261016000000_phase2_command_ledger). The simple
// organizationId -> Org(id) FK below is Prisma-expressible and covers org-scoped rows.
model CommandExecution {
  id             String    @id @default(uuid())
  scopeKind      String // 'project' | 'org'
  organizationId String
  projectId      String? // NULL for org-scoped commands (the scope CHECK enforces this)
  actorId        String
  commandType    String
  idempotencyKey String
  requestHash    String
  status         String // 'reserved' | 'succeeded' | 'failed'
  resultRef      String? // the committed entity id (Decision.id, …), replayed to the same actor+scope
  createdAt      DateTime  @default(now())
  completedAt    DateTime?

  org Org @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
}

// A firm/consultant associated with a project — the client company, the main
// contractor, the structural/MEP consultants, etc. Distinct from Membership (which
// is a *person* with a login role); a company is an organisation + a contact.
model ProjectCompany {
  id           String   @id @default(cuid())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId    String
  name         String // firm / organisation name
  kind         String // client | contractor | architect | structural | mep | pmc | consultant | other
  contactName  String?
  contactEmail String?
  contactPhone String?
  notes        String?
  createdAt    DateTime @default(now())

  @@index([projectId])
}

// An Org/Account (an architecture practice, e.g. "Vitan Architecture") — owns
// projects and the people who administer them. Multi-tenant foundation.
model Org {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique
  createdAt DateTime        @default(now())
  projects  Project[]
  members   OrgMembership[]
  modules   TemplateModule[]
  templates ProjectTemplate[]
  commandExecutions CommandExecution[]
}

// Templates Slice 3 (docs/TEMPLATES.md): a named PRESET — an ordered selection of modules
// ("G+2 Residence" = Ground Floor + Second Floor + Terrace + Standard QA). Picking a preset
// at Create Project expands its items through the same module instantiation as an
// à-la-carte pick. Editing a preset never touches already-created projects.
model ProjectTemplate {
  id          String    @id @default(cuid())
  org         Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId       String
  name        String
  version     Int       @default(1) // informational in v1 (design decision #5)
  description String    @default("")
  items       Json // [{ moduleId, count?, underZone? }] — validated against org modules on save
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([orgId])
}

// Templates Slice 2 (docs/TEMPLATES.md): a reusable menu item — a slice of project
// STRUCTURE (a location subtree, phases + planned activities, checklist definitions)
// scoped to one space/area/discipline, composed in any mix at Create Project. Org-owned:
// templates are "methods" and live on the Org; instances always belong to a project
// (see TENANCY.md). Content is a Zod-validated JSON payload with payload-internal node
// keys — instantiation mints fresh ids, so a module is fully self-contained.
model TemplateModule {
  id          String    @id @default(cuid())
  org         Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId       String
  name        String
  category    String // space | zone | element | discipline | schedule
  // where the module's ROOT nodes graft: null = top level (roots are zones / project-wide),
  // 'zone' = roots are rooms (need a zone), 'room' = roots are elements (need a room)
  anchorKind  String?
  version     Int       @default(1) // informational in v1 (design decision #5)
  description String    @default("")
  payload     Json // { nodes?, phases?, activities?, inspections? } — see contracts.modulePayloadSchema
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([orgId, category])
}

// Who can administer an org: owner/admin create projects + manage teams; member
// is a plain participant. Distinct from a project role (pmc/client/…).
model OrgMembership {
  id        String   @id @default(cuid())
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      String // owner | admin | member
  createdAt DateTime @default(now())

  @@unique([orgId, userId])
  @@index([userId])
}

// A user's access to a specific project, with the role they hold there. A user
// can have memberships on several projects (different roles on each). This is the
// grant the app scopes tokens to; the legacy User.projectId/role is the default.
model Membership {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      String // pmc | client | engineer | contractor | consultant
  // For a `consultant` member: the discipline they cover (architect | mep | lighting | …).
  // A label, not a permission — every consultant shares the same read-mostly role.
  discipline String?
  status    String   @default("active") // invited | active | removed
  createdAt DateTime @default(now())

  // drawing distributions frozen against this membership (Phase 1 Task 3)
  drawingRecipients DrawingRecipient[]
  // corrective/reinspection work assigned to this membership (Phase 1 Task 4)
  inspectionAssignments Inspection[]
  // completion claims recorded against this membership (Phase 1 Task 5)
  completionClaims Activity[] @relation("CompletionClaims")

  @@unique([projectId, userId])
  @@index([userId])
}

// A browser Web Push subscription (Phase 8). Endpoint is unique per device;
// notifications for a project fan out to all its subscriptions. When no VAPID
// keys are configured the send path is a no-op (dev stub).
model PushSubscription {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id])
  projectId String
  endpoint  String   @unique
  p256dh    String
  auth      String
  role      String?
  createdAt DateTime @default(now())
}

// An uploaded site photo (geo + timestamp, zoomable on the client). Phase
// 7c-media. Storage is provider-agnostic: with S3/R2 configured the bytes live
// in the bucket and `url` points at them; with no provider the bytes are kept
// in `data` (dev stub) and served from GET /media/:id. `decisionId`/`dailyLogId`
// are loose links to what the photo documents.
model Media {
  id         String   @id @default(cuid())
  project    Project  @relation(fields: [projectId], references: [id])
  projectId  String
  kind       String // progress | inspection | decision | attendance | material
  mime       String
  data       Bytes? // dev stub: bytes in the DB; null once stored in S3/R2
  url        String? // set in S3/R2 mode; null for the dev stub
  storageKey String?
  sizeBytes  Int      @default(0)
  geoLat     Float?
  geoLng     Float?
  takenAt    String? // display timestamp, e.g. "03 Jul 2026 · 9:12 AM"
  uploadedBy String
  // Project-owned references: composite (projectId, x) FKs — PostgreSQL rejects a
  // link to another project's record even on a direct write. NoAction because the
  // owning projectId is non-null (SET NULL would null it too); deletion behavior
  // is service-owned. Phase 0 Task 5.
  decision   Decision? @relation(fields: [projectId, decisionId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  decisionId String?
  dailyLog   DailyLog? @relation(fields: [projectId, dailyLogId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  dailyLogId String?
  // The place this photo shows the reality of (zone/room/object). The location tree is
  // the shared spatial spine: a photo here + a drawing on the same node = intent vs reality
  // for one object. SET NULL so removing a node never deletes the photo. Location spine.
  node       ProjectNode? @relation(fields: [projectId, nodeId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  nodeId     String?
  // The evidence containment CHAIN (Phase 1 Task 4): (projectId, inspectionId) proves
  // the inspection belongs to this project; (inspectionId, inspectionItemId) proves the
  // item belongs to THAT inspection. Raw SQL cannot pair inspection A with an item of
  // inspection B, and the CHECK "Media_item_requires_inspection" (raw SQL — Prisma can't
  // express CHECKs) closes the MATCH SIMPLE escape: a non-null item with a NULL
  // inspection would bypass the composite FK entirely, so it is forbidden outright.
  inspection       Inspection?     @relation(fields: [projectId, inspectionId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  inspectionId     String?
  inspectionItem   InspectionItem? @relation(fields: [inspectionId, inspectionItemId], references: [inspectionId, id], onDelete: NoAction, onUpdate: NoAction)
  inspectionItemId String?
  // PROJECT-SCOPED idempotency for offline replays — the same (projectId, clientKey)
  // is the same photo, uploaded exactly once. Never a global unique.
  clientKey  String?
  createdAt  DateTime @default(now())
  // overrides citing this photo as supporting evidence (Phase 1 Task 6)
  gateOverrides GateOverride[]

  @@unique([projectId, id]) // referenced identity (Task 6 override evidence)
  @@unique([projectId, clientKey])
  @@index([projectId, kind])
  @@index([nodeId])
  @@index([inspectionId])
}

// A controlled drawing in the project's register (the source of truth the team
// builds from). Identified by its number within the project; each issue is a
// DrawingRevision, the latest non-superseded one being "current". Files are held
// by StorageService (S3/R2 or the DB dev stub), same as Media. Slice 1.
model Drawing {
  id         String            @id @default(cuid())
  project    Project           @relation(fields: [projectId], references: [id])
  projectId  String
  number     String // e.g. "A-201"
  title      String
  discipline String // architectural | structural | mep | other
  zone       String?
  // Project-owned references (composite FKs, same rationale as Media). The activity
  // link is severed by ActivitiesService.remove BEFORE the activity row is deleted.
  activity   Activity? @relation(fields: [projectId, activityId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  activityId String? // the work this drawing governs (Slice 2 linkage)
  decision   Decision? @relation(fields: [projectId, decisionId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  decisionId String?
  // The place this drawing governs (zone/room/object). Filed at its natural level — a
  // floor plan on the zone, a joinery detail on the element — and inherited DOWN: a room
  // shows every drawing filed on it or any ancestor. A node delete keeps the drawing
  // (it becomes unfiled) — NodesService unlinks in-transaction; the composite FK makes
  // a cross-project filing impossible even on a direct write. Location spine.
  node       ProjectNode?      @relation(fields: [projectId, nodeId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  nodeId     String?
  // Draft → Publish lifecycle (mirrors Decision). While `publishedAt` is null the drawing is
  // a private DRAFT: the snapshot delivers it only to its author, it never notifies the build
  // team, and it's absent from the register / Site Map. Publishing issues it. Both nullable/
  // additive; existing rows backfilled to createdAt so nothing becomes an invisible draft.
  publishedAt DateTime?
  authorId   String?
  createdAt  DateTime          @default(now())
  revisions  DrawingRevision[]

  @@unique([projectId, number])
  @@unique([projectId, id]) // composite identity — tenant-safe containment target (Phase 1 Task 3)
  @@index([projectId])
  @@index([nodeId])
}

// One issued revision of a drawing (Rev A, B, C…). Supersession is SCOPED
// (Phase 1 Task 3): a for_construction issue supersedes only the prior
// for_construction set; a for_review issue supersedes NOTHING — it coexists
// as a review copy and can never govern the field.
model DrawingRevision {
  id         String   @id @default(cuid())
  // Containment: the revision's project IS its parent drawing's project — the
  // composite FK makes a cross-project revision row impossible even on a direct write.
  drawing    Drawing  @relation(fields: [projectId, drawingId], references: [projectId, id], onDelete: Cascade)
  drawingId  String
  projectId  String
  rev        String // "A" | "B" | "C" …
  // for_review | for_construction | superseded. AT MOST ONE live for_construction
  // revision may exist per drawing — enforced by the partial unique index
  // "DrawingRevision_one_construction_per_drawing" ON ("drawingId") WHERE
  // status = 'for_construction' (raw SQL in 20260925000000_phase1_drawing_governing;
  // Prisma cannot express partial uniques). The service serializes issues/publishes
  // on the parent Drawing row (SELECT … FOR UPDATE); this index is the DB backstop.
  status     String
  mime       String
  data       Bytes? // dev stub: bytes in the DB; null once stored in S3/R2
  url        String? // set in S3/R2 mode; null for the dev stub
  storageKey String?
  sizeBytes  Int      @default(0)
  note       String   @default("")
  issuedBy   String
  issuedAt   String // display timestamp, e.g. "08 Jul 2026"
  // Stamped when the recipient snapshot executed — EVEN when it froze an empty set.
  // null = the revision predates recipient snapshots (legacy); the migration never
  // invents snapshots, and Task 6's readiness truth table treats the two differently.
  recipientsFrozenAt DateTime?
  createdAt  DateTime @default(now())
  acks       DrawingAck[]
  recipients DrawingRecipient[]

  @@unique([projectId, id]) // composite identity — tenant-safe reference target (Task 3)
  @@unique([drawingId, rev]) // one Rev B per drawing — a duplicate label is a 409
  @@index([drawingId])
}

// WHO a revision was issued to — frozen at issue time (Phase 1 Task 3). The rows
// snapshot the project's ACTIVE engineer/contractor members at the moment of issue;
// membership churn never rewrites them (readiness derives recipients ∩ currently-
// active members in Task 6). Both FKs are composite so PostgreSQL itself refuses a
// recipient naming another project's revision or a user with no membership here.
// Memberships are soft-removed (status='removed'), never deleted, so NO ACTION is safe.
model DrawingRecipient {
  id          String          @id @default(cuid())
  projectId   String
  revision    DrawingRevision @relation(fields: [projectId, revisionId], references: [projectId, id], onDelete: Cascade)
  revisionId  String
  membership  Membership      @relation(fields: [projectId, userId], references: [projectId, userId], onDelete: NoAction, onUpdate: NoAction)
  userId      String
  roleAtIssue String // engineer | contractor — the role held when the set was frozen
  createdAt   DateTime        @default(now())

  @@unique([revisionId, userId])
  @@index([projectId, userId])
}

// A build-acknowledgement: a contractor / engineer confirming they are building
// to a specific revision ("building to Rev C"). Per-revision, so a superseding
// issue starts a fresh round of acks — the PMC can see who is on the current set.
model DrawingAck {
  id         String          @id @default(cuid())
  revision   DrawingRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  revisionId String
  userId     String
  userName   String
  role       String
  at         DateTime        @default(now())

  @@unique([revisionId, userId])
  @@index([revisionId])
}

// A real account: PMC / client / contractor sign in with email + password;
// site engineers are provisioned on first successful phone OTP. Passwordless
// dev auth (the "Viewing as" persona switch) is separate and gated by
// ALLOW_DEV_AUTH. Phase 7c-auth.
model User {
  id                String    @id @default(cuid())
  project           Project   @relation(fields: [projectId], references: [id])
  projectId         String
  role              String // pmc | client | engineer | contractor
  name              String
  email             String?   @unique
  phone             String?   @unique
  passwordHash      String?
  emailVerifiedAt   DateTime?
  credentialVersion Int       @default(0)
  createdAt         DateTime  @default(now())

  orgMemberships OrgMembership[]
  memberships    Membership[]
  passwordChallenges PasswordCredentialChallenge[]
  securityEvents     SecurityAuditEvent[]          @relation("SecurityEventTarget")
  securityActorEvents SecurityAuditEvent[]         @relation("SecurityEventActor")
}

// Durable, purpose-bound proof used only to establish or reset a password. It
// never represents an application session and stores no reusable secret.
model PasswordCredentialChallenge {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose             String
  otpHash             String
  attempts            Int       @default(0)
  expiresAt           DateTime
  verifiedAt          DateTime?
  setupTokenHash      String?   @unique
  setupTokenExpiresAt DateTime?
  consumedAt          DateTime?
  createdAt           DateTime  @default(now())

  @@index([userId, purpose, consumedAt])
  @@index([expiresAt])
}

// Identity-level security trail. Password recovery is not a project event, so
// it must not be forced into the project operations AuditLog.
model SecurityAuditEvent {
  id            String   @id @default(uuid()) @db.Uuid
  action        String
  targetUserId  String
  targetUser    User     @relation("SecurityEventTarget", fields: [targetUserId], references: [id], onDelete: Restrict)
  actorUserId   String?
  actorUser     User?    @relation("SecurityEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorKind     String
  correlationId String
  payload       Json?
  createdAt     DateTime @default(now())

  @@index([targetUserId, createdAt])
  @@index([actorUserId, createdAt])
}

// A worker's device identity (QR / tap-photo job card) — no account, no
// password. Each tap mints a short-lived scoped token recorded here for
// attribution. Phase 7c-auth.
model WorkerDevice {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id])
  projectId String
  name      String?
  trade     String?
  token     String   @unique
  createdAt DateTime @default(now())
  lastSeen  DateTime @default(now())
}

// A node in a project's location tree: zone → room → element (the object). Decisions
// (and later activities / inspections / materials) attach to a node so they can be
// grouped, filtered and browsed by where they live in the building.
model ProjectNode {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  // Composite self-FK: a node can only hang under a parent in the SAME project —
  // PostgreSQL rejects a cross-project tree edge even on a direct write. Cascade
  // still removes the subtree when a parent goes.
  parent    ProjectNode?  @relation("NodeChildren", fields: [projectId, parentId], references: [projectId, id], onDelete: Cascade, onUpdate: NoAction)
  parentId  String?
  name      String
  kind      String // zone | room | element
  order     Int      @default(0)
  // Draft → Publish lifecycle (mirrors Decision/Drawing). A node with a null `publishedAt` is a
  // private DRAFT: it's delivered only to its author and hidden from the team's Site Map and the
  // filing pickers — so no published item can ever be filed on a draft node (the invariant that
  // keeps the location spine safe). Publishing a node publishes its subtree + draft ancestors.
  publishedAt DateTime?
  authorId  String?
  createdAt DateTime @default(now())

  children    ProjectNode[]  @relation("NodeChildren")
  decisions   Decision[]
  media       Media[]
  drawings    Drawing[]
  activities  Activity[]
  inspections Inspection[]
  materials   SiteMaterial[]

  // composite identity for the (projectId, nodeId) FKs — see Media/Decision/…
  @@unique([projectId, id])
  @@index([projectId])
  @@index([parentId])
}

model Decision {
  id             String           @id // e.g. "DL-014"
  project        Project          @relation(fields: [projectId], references: [id])
  projectId      String
  title          String
  room           String // display fallback / legacy; the node path is authoritative when nodeId is set
  node           ProjectNode?     @relation(fields: [projectId, nodeId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  nodeId         String?
  status         DecisionStatus   @default(pending)
  ageDays        Int?
  photoSwatch    String
  approvedOption String?
  material       String?
  approver       String? // human-readable approver line (the caller's REAL name since Phase 1 Task 2)
  approvedById   String? // the approving user's id — real attribution (Phase 1 Task 2)
  onBehalfOf     String? // 'client' when a PMC approves on the client's behalf — never disguised
  date           String? // display date, e.g. "12 Jun 2026"
  cost           Int? // rupees
  createdAt      DateTime         @default(now())
  // Draft → Publish lifecycle. While `publishedAt` is null the decision is a private
  // DRAFT: the snapshot delivers it only to its author (`authorId`), it never notifies
  // the client, and the app treats it as weightless (no pending count, no gate). Publish
  // sets `publishedAt` and fires the normal side-effects. Both nullable/additive so the
  // migration is safe on the live DB; existing rows (published) are backfilled to createdAt.
  publishedAt    DateTime?
  authorId       String?

  options        DecisionOption[]
  events         DecisionEvent[]
  changeRequests ChangeRequest[]
  activities     Activity[]
  materials      SiteMaterial[]
  media          Media[]
  drawings       Drawing[]

  // composite identity so referencing models can carry (projectId, decisionId)
  // foreign keys — the DB itself rejects a cross-project link (Phase 0 Task 5)
  @@unique([projectId, id])
  // pre-existing in the DB since 20260715000000_add_location_tree; declared here so
  // the schema matches the database exactly (drift found by `prisma migrate diff`)
  @@index([nodeId])
}

model DecisionOption {
  id          String   @id @default(cuid())
  decision    Decision @relation(fields: [decisionId], references: [id])
  decisionId  String
  label       String
  optionKey   String
  material    String
  delta       Int // rupees
  swatch      String
  photoUrl    String? // uploaded sample photo (media url); swatch is the fallback
  recommended Boolean  @default(false)
  order       Int      @default(0)
}

// Append-only lifecycle + audit log for a decision.
model DecisionEvent {
  id         String   @id @default(cuid())
  decision   Decision @relation(fields: [decisionId], references: [id])
  decisionId String
  type       String // drafted | issued | approved | reapproved | change_requested | change_withdrawn
  actor      String // legacy display label; actorName is authoritative on new rows
  actorId    String? // real user identity (Phase 1 Task 2); null on pre-Phase-1 rows
  actorName  String?
  actorRole  String? // the role HELD AT ACTION TIME (gate finding 6) — a later role change never rewrites history
  at         DateTime @default(now())
  payload    Json?
}

// One reopening of a locked decision. Status machine: 'open' -> 'resolved' (by
// client re-approval) | 'withdrawn' (by the requester or PMC). EXACTLY ONE open
// request per decision is enforced by a partial unique index —
// "ChangeRequest_one_open_per_decision" ON ("decisionId") WHERE status = 'open'
// (raw SQL in 20260910000000_phase1_change_control; not expressible in Prisma).
// Legacy rows were backfilled: 'pending' -> 'open' only while their decision was
// still reopened, else 'resolved' with a null resolution.
model ChangeRequest {
  id             String    @id @default(cuid())
  decision       Decision  @relation(fields: [decisionId], references: [id])
  decisionId     String
  reason         String
  costImpact     Int // rupees
  timeImpactDays Int
  status         String    @default("open")
  requestedById  String? // real requester identity; null on pre-Phase-1 rows
  resolvedById   String?
  resolvedAt     DateTime?
  resolution     String? // 'reapproved' | 'withdrawn'; null on backfilled legacy rows
  createdAt      DateTime  @default(now())
}

model Activity {
  id             String         @id // e.g. "ACT-31"
  project        Project        @relation(fields: [projectId], references: [id])
  projectId      String
  name           String
  zone           String
  status         ActivityStatus @default(not_started)
  // planned/actual as day-offsets from 1 Jun 2026 (LEGACY prototype timeline model —
  // kept for compatibility; the civil dates below are canonical going forward)
  plannedStart   Int
  plannedEnd     Int
  actualStart    Int?
  actualEnd      Int?
  // Real civil dates (Phase 0 Task 6); display strings are derived, never compared
  plannedStartDate DateTime? @db.Date
  plannedEndDate   DateTime? @db.Date
  actualStartDate  DateTime? @db.Date
  actualEndDate    DateTime? @db.Date
  // Phase 1 Task 5 — the sign-off civil day (set ONLY by closing-inspection
  // approval); actualEndDate above remains the CLAIMED work-end day
  doneAt           DateTime? @db.Date
  // The completion CLAIM: who said the work was finished (an attributable,
  // membership-validated fact — the reject path assigns corrective work from it).
  // Composite FK to Membership — a claimant without a membership on THIS
  // project is impossible even on a direct write (memberships are soft-removed).
  completionRequestedBy     Membership? @relation("CompletionClaims", fields: [projectId, completionRequestedById], references: [projectId, userId], onDelete: NoAction, onUpdate: NoAction)
  completionRequestedById   String?
  completionRequestedByName String?
  completionRequestedAt     DateTime?
  block          String?
  // stored readiness gates; the Decision gate is derived live from the decision
  gateMaterial   GateState @default(na)
  gateTeam       GateState @default(na)
  gateInspection GateState @default(na)
  decision       Decision?      @relation(fields: [projectId, decisionId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  decisionId     String?
  phase          Phase?         @relation(fields: [projectId, phaseId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  phaseId        String?
  // Location spine: where this work happens (zone/room/object). NodesService unlinks
  // on node delete; the composite FK forbids a cross-project filing at the database.
  node           ProjectNode?   @relation(fields: [projectId, nodeId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  nodeId         String?
  order          Int            @default(0)
  drawings       Drawing[]
  // inspections whose requirement edge names this activity (Phase 1 Task 4)
  inspections    Inspection[]
  // manual readiness exceptions — attributable, evidenced, EXPIRING (Phase 1 Task 6)
  gateOverrides  GateOverride[]

  @@unique([projectId, id])
  @@index([nodeId])
}

// A manual readiness exception (Phase 1 Task 6): the PMC overrides ONE gate's
// derived value with an attributable, reasoned, optionally evidenced record that
// ALWAYS expires — expiry (or early revocation) restores the derivation. No
// silent flag-flips: every override is audited and serialized in the snapshot.
model GateOverride {
  id         String    @id @default(cuid())
  project    Project   @relation(fields: [projectId], references: [id])
  projectId  String
  // composite FK — an override can only name THIS project's activity
  activity   Activity  @relation(fields: [projectId, activityId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  activityId String
  gate       String // decision | material | team | inspection | drawing
  state      GateState
  reason     String
  actorId    String
  actorName  String
  // optional supporting photo — composite FK, same-project by construction (Task 4 key)
  evidence        Media?  @relation(fields: [projectId, evidenceMediaId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  evidenceMediaId String?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  @@index([projectId, activityId])
}

// A project phase (Foundation → Structure → MEP → Finishing…). Groups activities
// for phase-level monitoring; planned window as day-offsets (like activities).
model Phase {
  id           String     @id @default(cuid())
  project      Project    @relation(fields: [projectId], references: [id])
  projectId    String
  name         String
  order        Int        @default(0)
  plannedStart Int        @default(0) // LEGACY day-offset (kept for compatibility)
  plannedEnd   Int        @default(0) // LEGACY day-offset (kept for compatibility)
  // Real civil dates (Phase 0 Task 6)
  plannedStartDate DateTime? @db.Date
  plannedEndDate   DateTime? @db.Date
  activities   Activity[]

  // composite identity for the (projectId, phaseId) FK on Activity
  @@unique([projectId, id])
  @@index([projectId])
}

model Inspection {
  id        String           @id // e.g. "INSP-22"
  project   Project          @relation(fields: [projectId], references: [id])
  projectId String
  kind      String // "checklist" (engineer draft) | "review" (submitted to PMC)
  title     String
  zone      String
  by        String?
  date      String // LEGACY display string (derived; never sorted or compared)
  inspectionDate DateTime? @db.Date // real civil date (Phase 0 Task 6)
  submitted Boolean          @default(false)
  decided   Boolean          @default(false)
  // Phase 1 Task 5: the UNAMBIGUOUS closing-sign-off marker (id-pattern matching
  // retired). Approving a closing inspection is what completes its activity.
  closing   Boolean          @default(false)
  // The REQUIREMENT EDGE (Phase 1 Task 4): the Activity this inspection accepts.
  // Composite FK — a cross-project edge is impossible even on a direct write.
  activity   Activity? @relation(fields: [projectId, activityId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  activityId String?
  // A reinspection names its predecessor and inherits its activityId. AT MOST ONE
  // direct child per rejected inspection — partial unique index
  // "Inspection_one_reinspection_child" ON ("reinspectionOfId") WHERE NOT NULL
  // (raw SQL in 20260930000000_phase1_inspection_evidence).
  reinspectionOf   Inspection?  @relation("Reinspection", fields: [projectId, reinspectionOfId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  reinspectionOfId String?
  reinspections    Inspection[] @relation("Reinspection")
  // WHO must correct the work: an ACTIVE engineer/contractor member (service-validated;
  // the Membership FK is the backstop — memberships are soft-removed, never deleted).
  assignee   Membership? @relation(fields: [projectId, assigneeId], references: [projectId, userId], onDelete: NoAction, onUpdate: NoAction)
  assigneeId String?
  dueDate    DateTime? @db.Date // real civil due date (decide-day + N days, PMC-overridable)
  // attribution (Phase 1 global rule): who submitted / decided
  submittedById   String?
  submittedByName String?
  decidedById     String?
  decidedByName   String?
  // Location spine: where this quality check happens. NodesService unlinks on node
  // delete; the composite FK forbids a cross-project filing at the database.
  node      ProjectNode?     @relation(fields: [projectId, nodeId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  nodeId    String?
  items     InspectionItem[]
  media     Media[]

  @@unique([projectId, id]) // composite identity — tenant-safe reference target (Task 4)
  @@index([nodeId])
}

model InspectionItem {
  id           String            @id @default(cuid())
  inspection   Inspection        @relation(fields: [inspectionId], references: [id])
  inspectionId String
  name         String
  order        Int               @default(0)
  // checklist fields
  state        String? // pass | fail | na
  // DEPRECATED display derivative (Task 4): real evidence is the LINKED Media rows;
  // this counter is never proof and never validated against.
  photos       Int               @default(0)
  note         String            @default("")
  // review fields
  result       InspectionResult?
  swatch       String?
  rejected     Boolean           @default(false)
  media        Media[]

  @@unique([inspectionId, id]) // containment identity for the Media chain (Task 4)
}

model DailyLog {
  id          String         @id @default(cuid())
  project     Project        @relation(fields: [projectId], references: [id])
  projectId   String
  date        String // LEGACY display string (derived; never sorted or compared)
  // The civil day the site work belongs to (Phase 0 Task 6) — "latest log" orders by
  // THIS first; createdAt (the immutable creation instant) is only the tie-breaker.
  logDate     DateTime?      @db.Date
  createdAt   DateTime       @default(now())
  checkedIn   Boolean        @default(false)
  checkinTime String?
  submitted   Boolean        @default(false)
  progress    Int            @default(0)
  crew        CrewRow[]
  materials   SiteMaterial[]
  media       Media[]

  // composite identity for (projectId, dailyLogId) FKs — see Media
  @@unique([projectId, id])
}

model CrewRow {
  id         String   @id @default(cuid())
  dailyLog   DailyLog @relation(fields: [dailyLogId], references: [id])
  dailyLogId String
  trade      String
  count      Int      @default(0)
  order      Int      @default(0)
}

model SiteMaterial {
  id         String    @id @default(cuid())
  // Canonical project ownership (Codex gate finding 4): a material belongs to ONE
  // project directly — the composite FKs below then make every reference (its log,
  // the approving decision, the staging place) provably same-project in PostgreSQL.
  project    Project   @relation(fields: [projectId], references: [id])
  projectId  String
  dailyLog   DailyLog  @relation(fields: [projectId, dailyLogId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  dailyLogId String
  decision   Decision? @relation(fields: [projectId, decisionId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  decisionId String?
  name       String
  qty        String
  zone       String
  matched    Boolean   @default(true)
  swatch     String
  photo      Boolean   @default(false)
  // Location spine: where this material was delivered / is staged. NodesService
  // unlinks on node delete; the composite FK forbids a cross-project filing.
  node       ProjectNode? @relation(fields: [projectId, nodeId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  nodeId     String?
  order      Int       @default(0)

  @@index([nodeId])
  @@index([projectId])
}

model Notification {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id])
  projectId String
  text      String
  color     String
  time      String // relative label, e.g. "2h ago" / "just now"
  at        DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  projectId String?
  actor     String // legacy display label (role string on pre-Phase-1 rows)
  actorId   String? // real user identity (Phase 1 Task 2); populated going forward
  actorRole String? // the role HELD AT ACTION TIME (gate finding 6)
  action    String
  entity    String
  entityId  String
  at        DateTime @default(now())
  payload   Json?
}
