// Vitan PMC — database schema (PostgreSQL via Prisma).
// Phase-7 Slice 1: the entities behind the project snapshot and the core
// mutations. Fields are aligned with the frontend domain model
// (apps/web / packages/shared) so the API returns shapes the client uses
// directly. Phase 7c-auth adds User (accounts + phone identity) and
// WorkerDevice (no-account device tokens). Media and offline-outbox tables
// arrive in later slices. See docs/DATA_MODEL.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DecisionStatus {
  pending
  approved
  change
}

enum ActivityStatus {
  not_started
  in_progress
  // Phase 1 Task 5: an engineer's completion CLAIM parks the activity here;
  // only the PMC's approval of the linked closing inspection writes `done`
  awaiting_signoff
  done
  blocked
}

enum GateState {
  ok
  wait
  fail
  na
}

enum InspectionResult {
  PASS
  FAIL
}

model Project {
  id           String   @id
  name         String
  short        String
  descriptor   String
  stage        String
  siteCode     String
  location     String   @default("") // site address / locality (free text)
  projStart    String
  projEnd      String
  // Real civil dates (Phase 0 Task 6). scheduleStartDate is the SCHEDULE ANCHOR —
  // the calendar day legacy day-offset 0 refers to (proven by characterization:
  // dayLabel(0) === '1 Jun'); display projStart/projEnd stay as legacy strings.
  scheduleStartDate DateTime? @db.Date
  scheduleEndDate   DateTime? @db.Date
  timeZone          String    @default("Asia/Kolkata")
  elapsedPct   Int
  todayDay     Int
  milestonePct Int
  createdAt    DateTime @default(now())
  archivedAt   DateTime? // soft-delete: hidden from listings/switcher/portfolio when set

  decisions     Decision[]
  activities    Activity[]
  inspections   Inspection[]
  dailyLogs     DailyLog[]
  notifications Notification[]
  users         User[]
  workerDevices WorkerDevice[]
  media         Media[]
  pushSubs      PushSubscription[]
  drawings      Drawing[]
  phases        Phase[]
  gateOverrides GateOverride[]
  // Tenant — NON-NULL since Phase 2 Task 4 (the event envelope's composite tenant key
  // (organizationId, projectId) references Project(orgId, id); a project cannot exist
  // without an org). Legacy null-org projects are backfilled by the migration's diagnostic,
  // which ABORTS rather than guess a tenant. @@unique([orgId, id]) is added in raw SQL.
  org           Org            @relation(fields: [orgId], references: [id])
  orgId         String
  memberships   Membership[]
  companies     ProjectCompany[]
  nodes         ProjectNode[]
  siteMaterials SiteMaterial[]
  eventStream   ProjectEventStream?
  domainEvents  DomainEvent[]

  // Composite identity the DomainEvent tenant FK references (Phase 2 Task 4) — proves an
  // event's (organizationId, projectId) is the project's REAL org, so org cannot be forged.
  @@unique([orgId, id])
  capabilities     ProjectCapability[]
  requirements     ActivityRequirement[]
  requirementRoots ActivityRequirementRoot[]
  materialSpecs    MaterialRequirementSpec[]
  approvedSubstitutions ApprovedSubstitution[]
  vendorBindings   ProjectVendor[]           @relation("projectVendorProject")
  requisitions     Requisition[]
  purchaseOrders   PurchaseOrder[]           @relation("purchaseOrderProject")
  stockLots           StockLot[]
  stockTransactions   StockTransaction[]
  materialIssues      MaterialIssue[]
  mismatchResolutions MismatchResolution[]
  // Phase 4 Task 1 — the labour module's project-contained rows (plan §§B/H)
  labourTrades          LabourTrade[]
  labourSkills          LabourSkill[]
  workers               Worker[]
  crews                 Crew[]
  crewMemberships       CrewMembership[]
  labourRequirementSpecs LabourRequirementSpec[]
  labourDemandSlices     LabourDemandSlice[]
}

// Phase 2 Task 4 — the per-project event stream counter. Exactly one row per project
// (created inside the project-creation transaction; backfilled for legacy projects).
// `emit()` locks this row (SELECT … FOR UPDATE via an atomic increment) and assigns the
// gap-safe `streamPosition` INSIDE the owning mutation transaction, so two concurrent
// commits on one project can never collide or skip a position.
model ProjectEventStream {
  projectId    String  @id
  nextPosition BigInt  @default(0)
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// Phase 2 Task 4 — the append-only domain-event store. Ordering is (projectId, streamPosition),
// NEVER occurredAt (display/audit only). The composite tenant FK (organizationId, projectId) ->
// Project(orgId, id), the attribution truth-table CHECK, and the BEFORE UPDATE OR DELETE
// append-only trigger are all added in raw SQL by 20261015000000_phase2_event_envelope
// (Prisma cannot express them). See packages/shared/src/platform/events.ts for the envelope.
model DomainEvent {
  eventId         String   @id @default(uuid())
  eventType       String
  payloadVersion  Int      @default(1)
  organizationId  String
  projectId       String
  streamPosition  BigInt
  siteId          String?
  actorId         String?
  actorKind       String // 'human' | 'system'
  systemActor     String? // NON-NULL iff actorKind='system' (a named constant system actor)
  entityType      String
  entityId        String
  occurredAt      DateTime @default(now()) // DISPLAY/AUDIT ONLY — never an ordering key
  correlationId   String?
  causedByEventId String?
  payload         Json?
  // Phase 2 fix-forward PR B — immutable dispatch metadata recorded at commit time: what external
  // consequences (socket invalidate / push body+roles) the command requested. NOT a projection
  // result and NEVER mutated after insert. NULL = a pre-intent legacy event (the scanner treats it
  // as an external no-op; it never invents a historical push). PR C supplies the final per-command
  // catalog; PR B persists a compatibility intent (effectKey 'compat.task6').
  dispatchIntent  Json?
  // Composite tenant FK → Project(orgId, id): a forged organizationId (not the project's own
  // org) is rejected by the DB. RESTRICT — an append-only event outlives soft-deletes.
  tenant          Project  @relation(fields: [organizationId, projectId], references: [orgId, id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([projectId, streamPosition])
  // Candidate key the OutboxDelivery composite FK references (PR B) — a delivery's copied
  // (projectId, streamPosition) can no longer disagree with its event's real coordinates.
  @@unique([eventId, projectId, streamPosition])
  @@index([projectId, streamPosition])
  @@index([eventType])
  deliveries      OutboxDelivery[]
}

// Phase 2 Task 6 — the per-consumer transactional outbox. For each DomainEvent, one
// OutboxDelivery row per registered consumer is written IN THE SAME mutation transaction, so a
// crash can never leave an event with no durable delivery work. A lease-based relay claims
// pending rows (a SHORT lease transaction — never a lock held across dispatch), dispatches to the
// consumer, and moves the row pending→leased→succeeded, or on a retryable failure clears the
// lease + backs off (attempts++, nextAttemptAt) back to pending, or on exhaustion → dead. There
// is NO ambiguous 'failed'. Contract: at-least-once delivery, effectively-once DB effects.
model OutboxDelivery {
  id             String      @id @default(uuid())
  // PR B — the composite FK binds the copied (projectId, streamPosition) to the event's REAL
  // coordinates, so a forged/mismatched delivery coordinate is rejected by PostgreSQL. Replaces
  // the Task-6 event-only FK. Cascade delete only ever fires for a disposable TRUNCATE reset.
  event          DomainEvent @relation(fields: [eventId, projectId, streamPosition], references: [eventId, projectId, streamPosition], onDelete: Cascade, onUpdate: Cascade)
  eventId        String
  projectId      String
  consumer       String
  consumerKind   String // 'ordered' | 'unordered'
  // PR B — every registered consumer gets a row for every event: 'dispatch' invokes the consumer,
  // 'noop' records the event was deliberately irrelevant (so an ordered cursor never waits behind
  // a stream position for which no row exists). Closed set; no inferred representation.
  deliveryAction String    @default("dispatch") // 'dispatch' | 'noop'
  streamPosition BigInt // copied from the event; ordered consumers checkpoint on it
  status         String    @default("pending") // 'pending' | 'leased' | 'succeeded' | 'dead'
  attempts       Int       @default(0)
  nextAttemptAt  DateTime  @default(now())
  leaseOwner     String?
  leaseExpiresAt DateTime?
  lastError      String?
  payload        Json? // consumer-specific dispatch data (e.g. Web Push {body, roles})
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  // PR B — a restrictive composite FK to the durable consumer catalog: a delivery's
  // (consumer, consumerKind) must name a declared catalog contract, and a catalog row that still
  // has deliveries cannot be deleted (Restrict). Deactivation stops new obligations, never deletes.
  catalog        OutboxConsumerCatalog @relation(fields: [consumer, consumerKind], references: [consumer, consumerKind], onDelete: Restrict, onUpdate: Cascade)

  @@unique([eventId, consumer]) // exactly one delivery row per (event, consumer)
  @@index([consumer, status, nextAttemptAt]) // the relay's claim scan
  @@index([consumer, projectId, streamPosition]) // an ordered consumer's per-project stream
}

// Phase 2 fix-forward PR B — the DURABLE consumer catalog. The relational pair
// (active OutboxConsumerCatalog row × DomainEvent row) is the obligation: exactly one
// OutboxDelivery must exist for it. This survives a process crash / rolling deploy without mutating
// the append-only DomainEvent — the scanner derives missing deliveries from this catalog. A changed
// kind/effect/version is a startup error requiring an explicit migration (never a silent reinterpret).
model OutboxConsumerCatalog {
  consumer       String   @id
  consumerKind   String // 'ordered' | 'unordered'
  consumerEffect String // 'db' | 'external'
  catalogVersion Int // the consumer CONTRACT version, not an app release
  active         Boolean  @default(true)
  registeredAt   DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deliveries     OutboxDelivery[]

  @@unique([consumer, consumerKind]) // the composite the OutboxDelivery FK references
}

// Phase 2 fix-forward PR B — a durable audit row for every operator dead-letter action
// (retry/redrive). Written IN THE SAME transaction as the action it records. Never stores event
// payloads or secrets.
model OutboxOperatorAction {
  id               String   @id @default(uuid())
  action           String // e.g. 'retry'
  deliveryId       String?
  consumer         String?
  projectId        String?
  eventId          String?
  operatorIdentity String
  reason           String
  priorError       String?
  at               DateTime @default(now())

  @@index([at])
}

// Phase 2 fix-forward PR B — declared now, sealed in PR C. A singleton row (CHECK key='singleton')
// records the external-effect coverage version that outbox-mode startup must match. PR B only
// declares the table; the audited seal transaction and the null-intent rejection trigger land in PR C.
model OutboxCutoverState {
  key             String   @id // singleton — CHECK (key = 'singleton')
  coverageVersion String
  sealedAt        DateTime @default(now())
  sealedBy        String
  reason          String
  updatedAt       DateTime @updatedAt
}

// Phase 2 Task 6 — a database consumer records one ProcessedEvent per (consumer, eventId) IN THE
// SAME transaction as its side effect (effectively-once). A duplicate dispatch finds the row and
// skips re-applying. External consumers (socket/push) are at-least-once and do not use this.
model ProcessedEvent {
  id          String   @id @default(uuid())
  consumer    String
  eventId     String
  processedAt DateTime @default(now())

  @@unique([consumer, eventId])
}

// Phase 2 Task 6 — an ordered (per-project) consumer advances this cursor CONTIGUOUSLY: it may
// not apply streamPosition N+1 before N. A slow/failed earlier position holds the cursor; a
// `dead` earlier position sets status='blocked' and the projection is visibly degraded until an
// operator resolves it — never a silent skip. `appliedPosition` NULL = nothing applied yet (next
// expected = 0); otherwise the next expected position is appliedPosition + 1.
model ProjectionCursor {
  id              String   @id @default(uuid())
  consumer        String
  projectId       String
  appliedPosition BigInt? // NULL = none applied yet
  status          String   @default("live") // 'live' | 'blocked'
  updatedAt       DateTime @updatedAt

  @@unique([consumer, projectId])
}

// Phase 2 Task 9 — a projection GENERATION: the rebuildable read-model instance a projection
// consumer serves + advances. Each (consumer, projectId) has a monotone series of generations;
// exactly ONE is 'active' at a time (a raw-SQL PARTIAL unique index — Prisma cannot express WHERE
// — enforces `one active per (consumer, projectId)`, added in 20261101000000_phase2_projection_generations).
//
// The live relay applies each ordered `db` projection delivery into the ACTIVE generation,
// advancing `appliedPosition` CONTIGUOUSLY (position N+1 waits for N; a `dead` earlier position
// sets cursorStatus='blocked' — visible degradation, never a silent skip). An ONLINE REBUILD
// builds a NEW 'building' generation from a consistent canonical snapshot + event replay, then a
// final ACTIVATION BARRIER (per project: hold the ProjectEventStream lock, read the final position
// H, apply through H, then atomically activate the new generation with appliedPosition=H and retire
// the old one before releasing the lock) hands over with zero gap — every event allocated afterward
// is > H and targets the new generation, so nothing commits into the retired one.
//
// Dedup is per generation on `(consumer, generation, streamPosition)`: within one generation
// `appliedPosition` is the contiguous high-water mark, and a generation has a SINGLE writer at any
// instant (the rebuilder while 'building', the relay once 'active' — the barrier hands off in one
// transaction), so an event applied by both the relay and a rebuild replay is idempotent (the later
// apply sees position ≤ appliedPosition and skips). Projection ROWS carry this `generation`'s id, so
// a building generation is invisible to serving until it is activated and a retired one is dropped.
model ProjectionGeneration {
  id              String    @id @default(uuid())
  consumer        String
  projectId       String
  generation      Int // monotone per (consumer, projectId); the highest is the newest
  status          String    @default("building") // 'building' | 'active' | 'retired'
  appliedPosition BigInt? // contiguous checkpoint INTO THIS generation (NULL = none applied yet)
  cursorStatus    String    @default("live") // 'live' | 'blocked' (a dead earlier position blocks)
  activatedAt     DateTime? // when this generation became 'active' (the barrier commit)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([consumer, projectId, generation])
  @@index([consumer, projectId, status])
}

// Phase 2 Task 9 — the DECISIONS read-model projection (the first module's rebuildable read path).
// One row per (generation, decision): the decisions module's `decisions.inbox` projection consumer
// refreshes it from the canonical Decision on every decision.* event, storing the SAME serialized
// DecisionDto the live snapshot produces (via decision-serialize.ts) plus the columns the query
// filters on. Generation-scoped: `generationId` names the ProjectionGeneration the row belongs to
// (a plain column, not an FK — the generation lifecycle is managed by the rebuilder + the consumer's
// dropGeneration hook, mirroring ProcessedEvent/ProjectionCursor), so a building generation is
// invisible to serving until activated and a retired one is dropped wholesale. The read query serves
// the ACTIVE generation's rows and applies the per-viewer authz filter at query time (a projection is
// never an RBAC bypass) — `status`/`publishedAt`/`authorId` are duplicated out of `dto` as the filter
// keys, and `dto` is the pre-serialized DecisionDto.
model DecisionProjection {
  id           String    @id @default(uuid())
  generationId String
  projectId    String
  decisionId   String
  status       String // 'pending' | 'approved' | 'change' — the readiness map + the pending filter
  publishedAt  DateTime? // NULL = a private DRAFT (author-only visibility)
  authorId     String? // the draft author (author-private visibility)
  dto          Json // the serialized DecisionDto (options + open changeRequest inlined), unfiltered
  updatedAt    DateTime  @updatedAt

  @@unique([generationId, decisionId])
  @@index([generationId, projectId])
}

// Phase 2 Task 10 — the DAILY-LOG read-model projection (the daily-log module's rebuildable read
// path). Unlike DecisionProjection (one row per decision), the daily-log slice is a per-PROJECT
// composite — the latest log core (crew + its own materials) plus every project material — so a
// generation holds exactly ONE row per project, keyed (generationId, projectId), storing the whole
// serialized slice `computeDailyLogSlice` produces. The `daily-log.inbox` projection consumer
// refreshes it from canonical state on every dailylog.*/material.* event. Generation-scoped:
// `generationId` names the ProjectionGeneration the row belongs to (a plain column, not an FK — the
// lifecycle is managed by the rebuilder + the consumer's dropGeneration hook). The slice carries NO
// per-viewer visibility (every project viewer sees the same daily-log), so the read query serves the
// ACTIVE generation's row with no query-time filter.
model DailyLogProjection {
  id           String   @id @default(uuid())
  generationId String
  projectId    String
  dto          Json // the serialized DailyLogSlice: { dailyLog: DailyLogCore | null, materials: SiteMaterial[] }
  updatedAt    DateTime @updatedAt

  @@unique([generationId, projectId])
}

// Phase 2 Task 10 — the DRAWINGS read-model projection (the drawings module's rebuildable read path).
// Like DailyLogProjection (one row per project, not per entity), the drawings register is a per-PROJECT
// composite — every drawing with its revision history + governing-revision distribution facts — so a
// generation holds exactly ONE row per project, keyed (generationId, projectId), storing the whole
// serialized VIEWER-INDEPENDENT base `computeDrawingsBase` produces (drawings-serialize.ts). The
// `drawings.inbox` projection consumer refreshes it from canonical state on every drawing.* event. The
// per-viewer fields (draft-author visibility, the viewer's ack/recipient state) and each revision's
// short-lived signed `url` are baked at READ time — the base is neither per-viewer nor time-limited, so
// the stored row is safe to reuse across viewers and never holds an expiring token. Generation-scoped:
// `generationId` names the ProjectionGeneration the row belongs to (a plain column, not an FK — the
// lifecycle is managed by the rebuilder + the consumer's dropGeneration hook).
model DrawingsProjection {
  id           String   @id @default(uuid())
  generationId String
  projectId    String
  dto          Json // the serialized DrawingsBase (viewer-independent register; url + viewer fields baked at read)
  updatedAt    DateTime @updatedAt

  @@unique([generationId, projectId])
}

model InspectionsProjection {
  id           String   @id @default(uuid())
  generationId String
  projectId    String
  dto          Json // the serialized InspectionsBase (viewer-independent; role gating + signed evidence baked at read)
  updatedAt    DateTime @updatedAt

  @@unique([generationId, projectId])
}

// Phase 2 Task 10 (Module 4) — the activities module's rebuildable read model (`activities.schedule`).
// ONE row per (generation, project): the serialized ACTIVITY-OWNED base (activities + overrides + phases
// as stored facts). Derived readiness is NEVER stored here — it depends on foreign modules' state
// (decisions/inspections/drawings) whose events this projection does not consume, so a stored conclusion
// could go silently stale; it is baked FRESH at read time through those modules' query contracts.
model ActivitiesProjection {
  id           String   @id @default(uuid())
  generationId String
  projectId    String
  dto          Json // the serialized ActivitiesBase (activity-owned facts only; readiness baked at read)
  updatedAt    DateTime @updatedAt

  @@unique([generationId, projectId])
}

// Phase 3 Task 6 — the SIXTH rebuildable projection: per-project UI material-readiness (§A/§G).
// Recompute-only: a consumer re-derives the material verdict for every activity with a material
// requirement from CANONICAL facts (coverageFor + the §A truth) on each relevant event. It feeds
// UI/Inbox/Dashboard/forecast ONLY — command authority (activities.start) reads canonical coverage
// in-tx, never this projection. Storing a derived verdict produces NO domain event (§G).
model MaterialReadinessProjection {
  id           String   @id @default(uuid())
  generationId String
  projectId    String
  dto          Json // { readings: { [activityId]: { v, reason, coveredQty, requiredQty } } }, activityId-sorted
  updatedAt    DateTime @updatedAt

  @@unique([generationId, projectId])
}

// Phase 2 Task 10 (Module 3) correction — the INSPECTION-OWNED evidence link. Item-level photo evidence
// was formerly read off the Media table by the inspections serializer (a cross-module read the projection
// could not observe when a photo was uploaded/removed). Each row is an inspection-owned link from an
// inspection item to a media identity, maintained by the inspections participant inside the media
// create/remove transaction (which also appends an inspection event, so the projection refreshes). The
// legacy Media linkage columns are RETAINED for compatibility; this table is the serializer's source.
// Standalone (no Prisma relations, mirroring InspectionsProjection); the FK backstops live in the
// correction migration. Backfilled from existing linked Media rows.
model InspectionEvidence {
  id               String   @id @default(uuid())
  projectId        String
  inspectionId     String
  inspectionItemId String
  mediaId          String
  createdAt        DateTime @default(now())

  @@unique([inspectionItemId, mediaId]) // one link per (item, media)
  @@index([projectId])
  @@index([mediaId])
  @@index([inspectionId])
}

// Phase 2 Task 5 — the command-idempotency ledger. One receipt per (scope, actor, commandType,
// idempotencyKey): a retried/duplicated command (offline replay, network retry, double-tap)
// reserves→executes→commits its succeeded receipt in ONE transaction, so the effect happens
// exactly once and a replay returns the stored result. Ordering/collision is enforced by
// SCOPE-SPECIFIC PARTIAL unique indexes (raw SQL — Prisma cannot express WHERE): project-scoped
// rows key on (projectId, actorId, commandType, idempotencyKey), org-scoped rows on
// (organizationId, …), so an org index never constrains a project row. The scope truth-table
// CHECK, the status CHECK and the composite project-scoped tenant FK (organizationId, projectId)
// -> Project(orgId, id) are raw SQL too (20261016000000_phase2_command_ledger). The simple
// organizationId -> Org(id) FK below is Prisma-expressible and covers org-scoped rows.
model CommandExecution {
  id             String    @id @default(uuid())
  scopeKind      String // 'project' | 'org'
  organizationId String
  projectId      String? // NULL for org-scoped commands (the scope CHECK enforces this)
  actorId        String
  commandType    String
  idempotencyKey String
  requestHash    String
  status         String // 'reserved' | 'succeeded' | 'failed'
  resultRef      String? // the committed entity id (Decision.id, …), replayed to the same actor+scope
  createdAt      DateTime  @default(now())
  completedAt    DateTime?

  org Org @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Phase 3 Task 4 — stock ledger rows recording this execution as their source action (§C)
  stockTransactions StockTransaction[]

  // Tasks 4–5 integrity correction (F1) — the project-contained candidate key a
  // StockTransaction's (projectId, sourceCommandId) composite FK references, so a ledger row
  // can only cite a command execution IN ITS OWN PROJECT.
  @@unique([projectId, id])
  @@index([organizationId])
  @@index([projectId])
}

// A firm/consultant associated with a project — the client company, the main
// contractor, the structural/MEP consultants, etc. Distinct from Membership (which
// is a *person* with a login role); a company is an organisation + a contact.
model ProjectCompany {
  id           String   @id @default(cuid())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId    String
  name         String // firm / organisation name
  kind         String // client | contractor | architect | structural | mep | pmc | consultant | other
  contactName  String?
  contactEmail String?
  contactPhone String?
  notes        String?
  createdAt    DateTime @default(now())

  @@index([projectId])
}

// An Org/Account (an architecture practice, e.g. "Vitan Architecture") — owns
// projects and the people who administer them. Multi-tenant foundation.
model Org {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique
  createdAt DateTime        @default(now())
  projects  Project[]
  members   OrgMembership[]
  modules   TemplateModule[]
  templates ProjectTemplate[]
  commandExecutions CommandExecution[]
  vendors           Vendor[]
}

// Templates Slice 3 (docs/TEMPLATES.md): a named PRESET — an ordered selection of modules
// ("G+2 Residence" = Ground Floor + Second Floor + Terrace + Standard QA). Picking a preset
// at Create Project expands its items through the same module instantiation as an
// à-la-carte pick. Editing a preset never touches already-created projects.
model ProjectTemplate {
  id          String    @id @default(cuid())
  org         Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId       String
  name        String
  version     Int       @default(1) // informational in v1 (design decision #5)
  description String    @default("")
  items       Json // [{ moduleId, count?, underZone? }] — validated against org modules on save
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([orgId])
}

// Templates Slice 2 (docs/TEMPLATES.md): a reusable menu item — a slice of project
// STRUCTURE (a location subtree, phases + planned activities, checklist definitions)
// scoped to one space/area/discipline, composed in any mix at Create Project. Org-owned:
// templates are "methods" and live on the Org; instances always belong to a project
// (see TENANCY.md). Content is a Zod-validated JSON payload with payload-internal node
// keys — instantiation mints fresh ids, so a module is fully self-contained.
model TemplateModule {
  id          String    @id @default(cuid())
  org         Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId       String
  name        String
  category    String // space | zone | element | discipline | schedule
  // where the module's ROOT nodes graft: null = top level (roots are zones / project-wide),
  // 'zone' = roots are rooms (need a zone), 'room' = roots are elements (need a room)
  anchorKind  String?
  version     Int       @default(1) // informational in v1 (design decision #5)
  description String    @default("")
  payload     Json // { nodes?, phases?, activities?, inspections? } — see contracts.modulePayloadSchema
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([orgId, category])
}

// Who can administer an org: owner/admin create projects + manage teams; member
// is a plain participant. Distinct from a project role (pmc/client/…).
model OrgMembership {
  id        String   @id @default(cuid())
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      String // owner | admin | member
  createdAt DateTime @default(now())

  @@unique([orgId, userId])
  @@index([userId])
}

// A user's access to a specific project, with the role they hold there. A user
// can have memberships on several projects (different roles on each). This is the
// grant the app scopes tokens to; the legacy User.projectId/role is the default.
model Membership {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      String // pmc | client | engineer | contractor | consultant
  // For a `consultant` member: the discipline they cover (architect | mep | lighting | …).
  // A label, not a permission — every consultant shares the same read-mostly role.
  discipline String?
  status    String   @default("active") // invited | active | removed
  createdAt DateTime @default(now())

  // drawing distributions frozen against this membership (Phase 1 Task 3)
  drawingRecipients DrawingRecipient[]
  // corrective/reinspection work assigned to this membership (Phase 1 Task 4)
  inspectionAssignments Inspection[]
  // completion claims recorded against this membership (Phase 1 Task 5)
  completionClaims Activity[] @relation("CompletionClaims")

  @@unique([projectId, userId])
  @@index([userId])
  responsibleFor ActivityRequirement[]
}

// A browser Web Push subscription (Phase 8). Endpoint is unique per device;
// notifications for a project fan out to all its subscriptions. When no VAPID
// keys are configured the send path is a no-op (dev stub).
model PushSubscription {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id])
  projectId String
  endpoint  String   @unique
  p256dh    String
  auth      String
  role      String?
  createdAt DateTime @default(now())
}

// An uploaded site photo (geo + timestamp, zoomable on the client). Phase
// 7c-media. Storage is provider-agnostic: with S3/R2 configured the bytes live
// in the bucket and `url` points at them; with no provider the bytes are kept
// in `data` (dev stub) and served from GET /media/:id. `decisionId`/`dailyLogId`
// are loose links to what the photo documents.
model Media {
  id         String   @id @default(cuid())
  project    Project  @relation(fields: [projectId], references: [id])
  projectId  String
  kind       String // progress | inspection | decision | attendance | material
  mime       String
  data       Bytes? // dev stub: bytes in the DB; null once stored in S3/R2
  url        String? // set in S3/R2 mode; null for the dev stub
  storageKey String?
  sizeBytes  Int      @default(0)
  geoLat     Float?
  geoLng     Float?
  takenAt    String? // display timestamp, e.g. "03 Jul 2026 · 9:12 AM"
  uploadedBy String
  // Project-owned references: composite (projectId, x) FKs — PostgreSQL rejects a
  // link to another project's record even on a direct write. NoAction because the
  // owning projectId is non-null (SET NULL would null it too); deletion behavior
  // is service-owned. Phase 0 Task 5.
  decision   Decision? @relation(fields: [projectId, decisionId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  decisionId String?
  dailyLog   DailyLog? @relation(fields: [projectId, dailyLogId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  dailyLogId String?
  // The place this photo shows the reality of (zone/room/object). The location tree is
  // the shared spatial spine: a photo here + a drawing on the same node = intent vs reality
  // for one object. SET NULL so removing a node never deletes the photo. Location spine.
  node       ProjectNode? @relation(fields: [projectId, nodeId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  nodeId     String?
  // The evidence containment CHAIN (Phase 1 Task 4): (projectId, inspectionId) proves
  // the inspection belongs to this project; (inspectionId, inspectionItemId) proves the
  // item belongs to THAT inspection. Raw SQL cannot pair inspection A with an item of
  // inspection B, and the CHECK "Media_item_requires_inspection" (raw SQL — Prisma can't
  // express CHECKs) closes the MATCH SIMPLE escape: a non-null item with a NULL
  // inspection would bypass the composite FK entirely, so it is forbidden outright.
  inspection       Inspection?     @relation(fields: [projectId, inspectionId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  inspectionId     String?
  inspectionItem   InspectionItem? @relation(fields: [inspectionId, inspectionItemId], references: [inspectionId, id], onDelete: NoAction, onUpdate: NoAction)
  inspectionItemId String?
  // PROJECT-SCOPED idempotency for offline replays — the same (projectId, clientKey)
  // is the same photo, uploaded exactly once. Never a global unique.
  clientKey  String?
  createdAt  DateTime @default(now())
  // overrides citing this photo as supporting evidence (Phase 1 Task 6)
  gateOverrides GateOverride[]
  // stock quality decisions citing this photo (Phase 3 Task 4) — the ledger is immutable, so
  // media backing a stock transaction is not deletable (InventoryParticipant refuses)
  stockEvidence StockTransaction[]

  @@unique([projectId, id]) // referenced identity (Task 6 override evidence)
  @@unique([projectId, clientKey])
  @@index([projectId, kind])
  @@index([nodeId])
  @@index([inspectionId])
}

// A controlled drawing in the project's register (the source of truth the team
// builds from). Identified by its number within the project; each issue is a
// DrawingRevision, the latest non-superseded one being "current". Files are held
// by StorageService (S3/R2 or the DB dev stub), same as Media. Slice 1.
model Drawing {
  id         String            @id @default(cuid())
  project    Project           @relation(fields: [projectId], references: [id])
  projectId  String
  number     String // e.g. "A-201"
  title      String
  discipline String // architectural | structural | mep | other
  zone       String?
  // Project-owned references (composite FKs, same rationale as Media). The activity
  // link is severed by ActivitiesService.remove BEFORE the activity row is deleted.
  activity   Activity? @relation(fields: [projectId, activityId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  activityId String? // the work this drawing governs (Slice 2 linkage)
  decision   Decision? @relation(fields: [projectId, decisionId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  decisionId String?
  // The place this drawing governs (zone/room/object). Filed at its natural level — a
  // floor plan on the zone, a joinery detail on the element — and inherited DOWN: a room
  // shows every drawing filed on it or any ancestor. A node delete keeps the drawing
  // (it becomes unfiled) — NodesService unlinks in-transaction; the composite FK makes
  // a cross-project filing impossible even on a direct write. Location spine.
  node       ProjectNode?      @relation(fields: [projectId, nodeId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  nodeId     String?
  // Draft → Publish lifecycle (mirrors Decision). While `publishedAt` is null the drawing is
  // a private DRAFT: the snapshot delivers it only to its author, it never notifies the build
  // team, and it's absent from the register / Site Map. Publishing issues it. Both nullable/
  // additive; existing rows backfilled to createdAt so nothing becomes an invisible draft.
  publishedAt DateTime?
  authorId   String?
  createdAt  DateTime          @default(now())
  revisions  DrawingRevision[]

  @@unique([projectId, number])
  @@unique([projectId, id]) // composite identity — tenant-safe containment target (Phase 1 Task 3)
  @@index([projectId])
  @@index([nodeId])
}

// One issued revision of a drawing (Rev A, B, C…). Supersession is SCOPED
// (Phase 1 Task 3): a for_construction issue supersedes only the prior
// for_construction set; a for_review issue supersedes NOTHING — it coexists
// as a review copy and can never govern the field.
model DrawingRevision {
  id         String   @id @default(cuid())
  // Containment: the revision's project IS its parent drawing's project — the
  // composite FK makes a cross-project revision row impossible even on a direct write.
  drawing    Drawing  @relation(fields: [projectId, drawingId], references: [projectId, id], onDelete: Cascade)
  drawingId  String
  projectId  String
  rev        String // "A" | "B" | "C" …
  // for_review | for_construction | superseded. AT MOST ONE live for_construction
  // revision may exist per drawing — enforced by the partial unique index
  // "DrawingRevision_one_construction_per_drawing" ON ("drawingId") WHERE
  // status = 'for_construction' (raw SQL in 20260925000000_phase1_drawing_governing;
  // Prisma cannot express partial uniques). The service serializes issues/publishes
  // on the parent Drawing row (SELECT … FOR UPDATE); this index is the DB backstop.
  status     String
  mime       String
  data       Bytes? // dev stub: bytes in the DB; null once stored in S3/R2
  url        String? // set in S3/R2 mode; null for the dev stub
  storageKey String?
  sizeBytes  Int      @default(0)
  note       String   @default("")
  issuedBy   String
  issuedAt   String // display timestamp, e.g. "08 Jul 2026"
  // Stamped when the recipient snapshot executed — EVEN when it froze an empty set.
  // null = the revision predates recipient snapshots (legacy); the migration never
  // invents snapshots, and Task 6's readiness truth table treats the two differently.
  recipientsFrozenAt DateTime?
  createdAt  DateTime @default(now())
  acks       DrawingAck[]
  recipients DrawingRecipient[]

  @@unique([projectId, id]) // composite identity — tenant-safe reference target (Task 3)
  @@unique([drawingId, rev]) // one Rev B per drawing — a duplicate label is a 409
  @@index([drawingId])
}

// WHO a revision was issued to — frozen at issue time (Phase 1 Task 3). The rows
// snapshot the project's ACTIVE engineer/contractor members at the moment of issue;
// membership churn never rewrites them (readiness derives recipients ∩ currently-
// active members in Task 6). Both FKs are composite so PostgreSQL itself refuses a
// recipient naming another project's revision or a user with no membership here.
// Memberships are soft-removed (status='removed'), never deleted, so NO ACTION is safe.
model DrawingRecipient {
  id          String          @id @default(cuid())
  projectId   String
  revision    DrawingRevision @relation(fields: [projectId, revisionId], references: [projectId, id], onDelete: Cascade)
  revisionId  String
  membership  Membership      @relation(fields: [projectId, userId], references: [projectId, userId], onDelete: NoAction, onUpdate: NoAction)
  userId      String
  roleAtIssue String // engineer | contractor — the role held when the set was frozen
  createdAt   DateTime        @default(now())

  @@unique([revisionId, userId])
  @@index([projectId, userId])
}

// A build-acknowledgement: a contractor / engineer confirming they are building
// to a specific revision ("building to Rev C"). Per-revision, so a superseding
// issue starts a fresh round of acks — the PMC can see who is on the current set.
model DrawingAck {
  id         String          @id @default(cuid())
  revision   DrawingRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  revisionId String
  userId     String
  userName   String
  role       String
  at         DateTime        @default(now())

  @@unique([revisionId, userId])
  @@index([revisionId])
}

// A real account: PMC / client / contractor sign in with email + password;
// site engineers are provisioned on first successful phone OTP. Passwordless
// dev auth (the "Viewing as" persona switch) is separate and gated by
// ALLOW_DEV_AUTH. Phase 7c-auth.
model User {
  id                String    @id @default(cuid())
  project           Project   @relation(fields: [projectId], references: [id])
  projectId         String
  role              String // pmc | client | engineer | contractor
  name              String
  email             String?   @unique
  phone             String?   @unique
  passwordHash      String?
  emailVerifiedAt   DateTime?
  credentialVersion Int       @default(0)
  createdAt         DateTime  @default(now())

  orgMemberships OrgMembership[]
  memberships    Membership[]
  passwordChallenges PasswordCredentialChallenge[]
  securityEvents     SecurityAuditEvent[]          @relation("SecurityEventTarget")
  securityActorEvents SecurityAuditEvent[]         @relation("SecurityEventActor")
  requirementRootsCreated ActivityRequirementRoot[]  @relation("requirementRootsCreated")
  requirementsCreated     ActivityRequirement[]      @relation("requirementsCreated")
  approvalsRecorded       DecisionApprovalRevision[] @relation("approvalRevisionsApproved")
  vendorsCreated          Vendor[]                   @relation("vendorsCreated")
  vendorsBound            ProjectVendor[]            @relation("vendorsBound")
  requisitionsCreated     Requisition[]              @relation("requisitionsCreated")
  rfqsIssued              Rfq[]                      @relation("rfqsIssued")
  quotesRecorded          VendorQuote[]              @relation("quotesRecorded")
  comparisonsCreated      QuoteComparison[]          @relation("comparisonsCreated")
  purchaseOrdersCreated   PurchaseOrder[]            @relation("purchaseOrdersCreated")
  poVersionsCreated       PurchaseOrderVersion[]     @relation("poVersionsCreated")
  commitmentsCreated      DeliveryCommitment[]       @relation("commitmentsCreated")
  promisesRecorded        DeliveryPromise[]          @relation("promisesRecorded")
  stockLotsReceived         StockLot[]         @relation("stockLotsReceived")
  stockTransactionsRecorded StockTransaction[] @relation("stockTransactionsRecorded")
  materialIssuesIssued      MaterialIssue[]      @relation("materialIssuesIssued")
  mismatchesResolved        MismatchResolution[] @relation("mismatchesResolved")
  substitutionsApproved     ApprovedSubstitution[] @relation("substitutionsApproved")
  substitutionsRevoked      ApprovedSubstitution[] @relation("substitutionsRevoked")
  // Phase 4 Task 1 — trusted-workforce identity attribution (plan §H)
  labourTradesCreated       LabourTrade[]  @relation("labourTradesCreated")
  labourSkillsCreated       LabourSkill[]  @relation("labourSkillsCreated")
  workersOnboarded          Worker[]       @relation("workersOnboarded")
  workersRevoked            Worker[]       @relation("workersRevoked")
  crewsFormed               Crew[]         @relation("crewsFormed")
  crewsRevoked              Crew[]         @relation("crewsRevoked")
  crewMembersAdded          CrewMembership[] @relation("crewMembersAdded")
  crewMembersRemoved        CrewMembership[] @relation("crewMembersRemoved")
}

// Durable, purpose-bound proof used only to establish or reset a password. It
// never represents an application session and stores no reusable secret.
model PasswordCredentialChallenge {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose             String
  otpHash             String
  attempts            Int       @default(0)
  expiresAt           DateTime
  verifiedAt          DateTime?
  setupTokenHash      String?   @unique
  setupTokenExpiresAt DateTime?
  consumedAt          DateTime?
  createdAt           DateTime  @default(now())

  @@index([userId, purpose, consumedAt])
  @@index([expiresAt])
}

// Identity-level security trail. Password recovery is not a project event, so
// it must not be forced into the project operations AuditLog.
model SecurityAuditEvent {
  id            String   @id @default(uuid()) @db.Uuid
  action        String
  targetUserId  String
  targetUser    User     @relation("SecurityEventTarget", fields: [targetUserId], references: [id], onDelete: Restrict)
  actorUserId   String?
  actorUser     User?    @relation("SecurityEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorKind     String
  correlationId String
  payload       Json?
  createdAt     DateTime @default(now())

  @@index([targetUserId, createdAt])
  @@index([actorUserId, createdAt])
}

// A worker's device identity (QR / tap-photo job card) — no account, no
// password. Each tap mints a short-lived scoped token recorded here for
// attribution. Phase 7c-auth.
model WorkerDevice {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id])
  projectId String
  // Phase 4 Task 1 (§H) — the trusted-identity binding: a device attributes attendance to a
  // first-class same-project Worker. NULLABLE so anonymous QR/tap onboarding (no Worker yet)
  // still works byte-for-byte; a bound device carries the composite (projectId, workerId) FK,
  // so a device can NEVER reference a Worker in another project. Free-text name/trade below are
  // display-only and are NEVER readiness evidence (the FK identity is).
  worker    Worker?  @relation(fields: [projectId, workerId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  workerId  String?
  name      String?
  trade     String?
  token     String   @unique
  createdAt DateTime @default(now())
  lastSeen  DateTime @default(now())
}

// A node in a project's location tree: zone → room → element (the object). Decisions
// (and later activities / inspections / materials) attach to a node so they can be
// grouped, filtered and browsed by where they live in the building.
model ProjectNode {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  // Composite self-FK: a node can only hang under a parent in the SAME project —
  // PostgreSQL rejects a cross-project tree edge even on a direct write. Cascade
  // still removes the subtree when a parent goes.
  parent    ProjectNode?  @relation("NodeChildren", fields: [projectId, parentId], references: [projectId, id], onDelete: Cascade, onUpdate: NoAction)
  parentId  String?
  name      String
  kind      String // zone | room | element
  order     Int      @default(0)
  // Draft → Publish lifecycle (mirrors Decision/Drawing). A node with a null `publishedAt` is a
  // private DRAFT: it's delivered only to its author and hidden from the team's Site Map and the
  // filing pickers — so no published item can ever be filed on a draft node (the invariant that
  // keeps the location spine safe). Publishing a node publishes its subtree + draft ancestors.
  publishedAt DateTime?
  authorId  String?
  createdAt DateTime @default(now())

  children    ProjectNode[]  @relation("NodeChildren")
  decisions   Decision[]
  media       Media[]
  drawings    Drawing[]
  activities  Activity[]
  inspections Inspection[]
  materials   SiteMaterial[]

  // composite identity for the (projectId, nodeId) FKs — see Media/Decision/…
  @@unique([projectId, id])
  @@index([projectId])
  @@index([parentId])
}

// ── Phase 3 Task 1 — pilot activation + the ActivityRequirement demand contract ─────────────

// Project-scoped capability activation (plan §D). A Phase-3 surface exists for a project ONLY
// when its capability row exists — non-pilot projects keep today's behavior byte-for-byte
// (routes 404, no Phase-3 events, stored gateMaterial semantics unchanged). Platform-owned.
model ProjectCapability {
  project     Project  @relation(fields: [projectId], references: [id])
  projectId   String
  capability  String // 'materials' (Stage 1)
  enabledAt   DateTime @default(now())
  enabledById String

  @@id([projectId, capability])
}

enum RequirementType {
  material
  labour
  equipment
  decision
  drawing
  inspection
}

// Phase 3 Task 1 correction — the requirement ROOT: the stable, project-contained identity a
// revision belongs to. Every revision row carries a composite FK to (projectId, rootId), so a
// revision lineage CROSSING projects is unrepresentable in PostgreSQL (review finding 2).
model ActivityRequirementRoot {
  id          String                @id // the stable requirementId
  project     Project               @relation(fields: [projectId], references: [id])
  projectId   String
  createdAt   DateTime              @default(now())
  createdBy   User                  @relation("requirementRootsCreated", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById String
  revisions   ActivityRequirement[]
  substitutions ApprovedSubstitution[]

  @@unique([projectId, id])
}

// The §11 demand contract (plan §§B/F) — TYPE-NEUTRAL revision rows (correction finding 3).
// APPEND-ONLY: a BEFORE UPDATE OR DELETE trigger (this correction's migration) makes every
// revision row database-immutable; revise/cancel INSERT revision+1 against the same root. The
// common contract keeps only type-neutral fields (§11: quantity + unit + dates + parties);
// material-only specification detail lives in the revision-owned MaterialRequirementSpec.
// Downstream phases FK onto (projectId, requirementId, revision).
model ActivityRequirement {
  id            String                  @id @default(cuid()) // row id (one per revision)
  project       Project                 @relation(fields: [projectId], references: [id])
  projectId     String
  root          ActivityRequirementRoot @relation(fields: [projectId, requirementId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  requirementId String
  revision      Int // 1-based, monotone per requirementId
  activity      Activity                @relation(fields: [projectId, activityId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  activityId    String
  type          RequirementType         @default(material)

  requiredQty Decimal  @db.Decimal(18, 6)
  baseUom     String
  requiredBy  DateTime @db.Date // civil DATE (correction finding 3)
  // the accountable party: an ACTIVE same-project membership (service-validated; FK backstop)
  responsible   Membership? @relation(fields: [projectId, responsibleId], references: [projectId, userId], onDelete: NoAction, onUpdate: NoAction)
  responsibleId String?
  criticality   String      @default("normal") // 'normal' | 'critical'
  tolerance     Decimal?    @db.Decimal(18, 6)
  status        String      @default("open") // 'open' | 'cancelled' (a cancel APPENDS a revision)
  createdAt     DateTime    @default(now())
  createdBy     User        @relation("requirementsCreated", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById   String

  materialSpec     MaterialRequirementSpec?
  labourSpec       LabourRequirementSpec? // Phase 4 Task 1 — the labour detail (type='labour')
  labourSlices     LabourDemandSlice[] // Phase 4 Task 1 — explicit (civilDate, shift, qty) slices
  requisitionLines RequisitionLine[]
  stockLots        StockLot[]

  @@unique([requirementId, revision])
  // the downstream-FK identity (correction finding 2): later phases pin exactly this triple
  @@unique([projectId, requirementId, revision])
  // composite identity so referencing rows can carry (projectId, rowId) FKs (Phase 0 Task 5 pattern)
  @@unique([projectId, id])
  @@index([projectId, activityId])
}

// The MATERIAL-ONLY specification detail of one requirement revision (correction finding 3):
// technical identity (fingerprinted, §B) + AUTHORITATIVE decision provenance (finding 1 —
// SERVER-derived from a real approved/reapproved decision + its selected option; the all-or-none
// rule is a database CHECK). Append-only via the same BEFORE UPDATE OR DELETE trigger.
model MaterialRequirementSpec {
  id            String              @id @default(cuid())
  project       Project             @relation(fields: [projectId], references: [id])
  projectId     String
  requirement   ActivityRequirement @relation(fields: [projectId, requirementId, revision], references: [projectId, requirementId, revision], onDelete: NoAction, onUpdate: NoAction)
  requirementId String
  revision      Int

  // The unit of measure lives ONCE, on the revision row (round-2 finding 4): the fingerprint
  // still hashes it as part of the §B identity, but there is no duplicated column to disagree.
  materialCategory     String
  make                 String
  grade                String
  normalizedAttributes String
  specFingerprint      String

  // AUTHORITATIVE decision provenance — all null (manual spec) or all server-resolved (CHECK).
  // Round-2 finding 2: the triple FKs onto the IMMUTABLE DecisionApprovalRevision register, so
  // a spec can only reference an approval that really happened, for a real selected option.
  decision         Decision?                 @relation(fields: [projectId, decisionId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  decisionId       String?
  approvalRevision DecisionApprovalRevision? @relation(fields: [projectId, decisionId, decisionVersion, optionKey], references: [projectId, decisionId, version, optionKey], onDelete: NoAction, onUpdate: NoAction)
  decisionVersion  Int?
  optionKey        String?

  @@unique([projectId, requirementId, revision])
  @@index([projectId, specFingerprint])
}

// Phase 3 Task 6 — an ACTIVE substitution admits stock of `toFingerprint` as satisfying a
// requirement whose §B identity is `fromFingerprint` (plan §B satisfaction rule). Keyed on the
// requirement ROOT (stable across revisions), pmc authority, audited, event-bearing. Revocation
// NEVER deletes — it stamps `revokedAt`; coverage re-derives WITHOUT the substitution from that
// point on. `coverageFor` (inventory) reads it ONLY indirectly: activities resolves each
// requirement's acceptable fingerprint set and passes it in, keeping the activities→inventory edge.
model ApprovedSubstitution {
  id            String                  @id @default(cuid())
  project       Project                 @relation(fields: [projectId], references: [id])
  projectId     String
  root          ActivityRequirementRoot @relation(fields: [projectId, requirementId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  requirementId String
  fromFingerprint String // the requirement's own §B technical-identity fingerprint
  toFingerprint   String // the substitute stock identity admitted as satisfying it
  reason        String
  approvedBy    User     @relation("substitutionsApproved", fields: [approvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approvedById  String
  at            DateTime @default(now())
  // revocation (append-in-place: the row survives, coverage re-derives without it)
  revokedAt     DateTime?
  revokedBy     User?     @relation("substitutionsRevoked", fields: [revokedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  revokedById   String?
  revokeReason  String?

  @@index([projectId, requirementId])
  @@index([projectId, toFingerprint])
  // Task 6 correction (F2): a PARTIAL unique index on
  // (projectId, requirementId, fromFingerprint, toFingerprint) WHERE "revokedAt" IS NULL forbids a
  // second ACTIVE row for the same material pair (revoked rows are excluded, so history survives and
  // re-approval after revocation is allowed). Prisma cannot express a partial index, so it lives in
  // migration 20270103000000_phase3_t6_correction (like the other DB-only Phase-3 constructs).
}


// ─── Phase 3 Task 2 — the procurement module (plan §§F/G/H) ────────────────────────────────
// Vendor is ORG-scoped — the ONE exception to the every-table-carries-projectId rule, because
// a vendor is an organization-level party (§H). Project reach is ONLY the additive
// ProjectVendor binding below, whose org provably matches both sides.
model Vendor {
  id          String   @id @default(cuid())
  org         Org      @relation(fields: [orgId], references: [id])
  orgId       String
  name        String
  contact     String?
  gstin       String?
  createdAt   DateTime @default(now())
  createdBy   User     @relation("vendorsCreated", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById String

  bindings ProjectVendor[]

  @@unique([orgId, id])
}

// §H — a vendor's explicit reach into ONE project. The composite FKs bind the SAME orgId to
// the vendor AND the project, so a cross-org binding is unrepresentable in PostgreSQL; every
// procurement row references (projectId, vendorId) THROUGH this binding.
model ProjectVendor {
  id        String   @id @default(cuid())
  projectId String
  orgId     String
  project   Project  @relation("projectVendorProject", fields: [orgId, projectId], references: [orgId, id], onDelete: NoAction, onUpdate: NoAction)
  vendor    Vendor   @relation(fields: [orgId, vendorId], references: [orgId, id], onDelete: NoAction, onUpdate: NoAction)
  vendorId  String
  boundAt   DateTime @default(now())
  boundBy   User     @relation("vendorsBound", fields: [boundById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  boundById String

  quotes         VendorQuote[]
  purchaseOrders PurchaseOrder[]

  @@unique([projectId, vendorId])
  @@unique([projectId, id])
}

// §F — a demand batch against pinned requirement revisions. CAS state machine:
// draft → submitted → approved | rejected; approved → closed (all lines ordered or cancelled).
model Requisition {
  id             String    @id @default(cuid())
  project        Project   @relation(fields: [projectId], references: [id])
  projectId      String
  title          String
  notes          String?
  status         String    @default("draft") // draft|submitted|approved|rejected|closed
  createdAt      DateTime  @default(now())
  createdBy      User      @relation("requisitionsCreated", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById    String
  submittedById  String? // transition attribution (audited + event-attributed, like Decision.approvedById)
  submittedAt    DateTime?
  approvedById   String?
  approvedAt     DateTime?
  rejectedReason String?
  closedAt       DateTime?

  lines          RequisitionLine[]
  rfqs           Rfq[]
  purchaseOrders PurchaseOrder[]

  @@unique([projectId, id])
}

// §F bound 1 — ONE allocation of base-UOM quantity against a pinned requirement revision
// (the Task-1 composite triple FK is the downstream target). Σ active allocations per
// revision ≤ its required qty — enforced in-transaction with the revision locked FOR UPDATE.
model RequisitionLine {
  id            String              @id @default(cuid())
  projectId     String
  requisition   Requisition         @relation(fields: [projectId, requisitionId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  requisitionId String
  requirement   ActivityRequirement @relation(fields: [projectId, requirementId, revision], references: [projectId, requirementId, revision], onDelete: NoAction, onUpdate: NoAction)
  requirementId String
  revision      Int
  qty           Decimal             @db.Decimal(18, 6) // in the revision's base UOM (single source)
  status        String              @default("open") // open|ordered|cancelled — 'ordered' = fully allocated to live POs (Task 3); open+ordered BOTH count toward §F bound 1
  cancelledAt   DateTime?
  cancelledById String?

  quoteLines VendorQuoteLine[]
  poLines    PurchaseOrderLine[]

  @@unique([projectId, id])
  // F4 correction: the FK target sealing a PO line's frozen requirement pin to ITS line's real pin
  @@unique([projectId, id, requirementId, revision])
  // F4-r2: the FK target sealing quote/PO line CONTAINMENT to their parent requisition
  @@unique([projectId, requisitionId, id])
  @@index([projectId, requirementId, revision])
}

// §F — an RFQ issued from an approved requisition: issued → closed (quotes in or expired).
model Rfq {
  id            String      @id @default(cuid())
  projectId     String
  requisition   Requisition @relation(fields: [projectId, requisitionId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  requisitionId String
  status        String      @default("issued") // issued|closed
  issuedAt      DateTime    @default(now())
  issuedBy      User        @relation("rfqsIssued", fields: [issuedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  issuedById    String
  closedAt      DateTime?

  quotes     VendorQuote[]
  comparison QuoteComparison?

  @@unique([projectId, id])
  // F4 correction: the FK target letting the comparison seal its requisition provenance
  @@unique([projectId, id, requisitionId])
}

// §F — one vendor's quote on an RFQ, reached THROUGH the ProjectVendor binding (§H).
// recorded → superseded (a newer quote from the same vendor) | expired (validity passed).
model VendorQuote {
  id              String        @id @default(cuid())
  projectId       String
  rfq             Rfq           @relation(fields: [projectId, rfqId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  rfqId           String
  // F4-r2: the RFQ's requisition, denormalized (immutable — the lifecycle trigger freezes it)
  // and FK-sealed (projectId, rfqId, requisitionId) -> Rfq, so every quote LINE can be
  // containment-sealed to this same requisition.
  requisitionId   String
  binding         ProjectVendor @relation(fields: [projectId, vendorId], references: [projectId, vendorId], onDelete: NoAction, onUpdate: NoAction)
  vendorId        String
  status          String        @default("recorded") // recorded|superseded|expired
  validUntil      DateTime      @db.Date
  leadTimeDays    Int?
  paymentTerms    String?
  warrantyTerms   String?
  historicalScore Decimal?      @db.Decimal(5, 2)
  recordedAt      DateTime      @default(now())
  recordedBy      User          @relation("quotesRecorded", fields: [recordedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  recordedById    String

  lines               VendorQuoteLine[]
  comparisonsSelected QuoteComparison[]

  @@unique([projectId, id])
  // F4 correction: the FK target proving a comparison's selection is a quote of the SAME
  // rfq AND that the recorded selectedVendorId is truly that quote's vendor. Rows are
  // lifecycle-only at PostgreSQL (status may transition; everything else is frozen), and
  // at most ONE 'recorded' quote per (projectId, rfqId, vendorId) — a partial unique index
  // (SQL migration; not expressible in Prisma).
  @@unique([projectId, rfqId, vendorId, id])
  // F4-r2: the FK target sealing each quote line's containment to THIS quote's requisition
  @@unique([projectId, id, requisitionId])
  @@index([projectId, rfqId, vendorId])
}

// §F quote normalization — the comparison inputs, per quoted requisition line. Money is
// Decimal in the project base currency (INR, Stage 1); landedCost is the comparison metric.
model VendorQuoteLine {
  id                   String          @id @default(cuid())
  projectId            String
  quote                VendorQuote     @relation(fields: [projectId, quoteId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  quoteId              String
  requisitionLine      RequisitionLine @relation(fields: [projectId, requisitionLineId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  requisitionLineId    String
  // F4-r2: containment — this line's requisition, FK-sealed BOTH to the parent quote's
  // requisition and to the requisition line's own requisition (a foreign line is
  // unrepresentable; rows are fully append-only).
  requisitionId        String
  baseRate             Decimal         @db.Decimal(18, 2)
  taxAmount            Decimal         @db.Decimal(18, 2)
  freightAmount        Decimal         @db.Decimal(18, 2)
  landedCost           Decimal         @db.Decimal(18, 2)
  quotedMake           String
  matchesSpecification Boolean
  sampleCompliant      Boolean?
  vendorStockQty       Decimal?        @db.Decimal(18, 6)
  deliveryPromise      DateTime?       @db.Date

  @@unique([quoteId, requisitionLineId])
  @@unique([projectId, id])
}

// §F — the recorded comparison decision: draft → approved, carrying REAL authority + reason;
// a non-lowest landed-total selection additionally demands an explicit justification. Only
// COMPLETE quotes (covering every open requisition line) are eligible; an offered material
// that does not match the approved specification cannot be selected (F1/F3 corrections —
// substitutions and partial awards are unsupported until their tasks land). Approval is
// SEALED at PostgreSQL: identity is frozen, only the approval columns may be written, and
// an approved row can never change again.
model QuoteComparison {
  id               String       @id @default(cuid())
  projectId        String
  rfq              Rfq          @relation(fields: [projectId, rfqId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  rfqId            String
  // F4 correction: the RFQ's requisition, denormalized + FK-sealed (projectId, rfqId,
  // requisitionId) -> Rfq so a purchase order can seal its full provenance chain.
  requisitionId    String
  status           String       @default("draft") // draft|approved
  selectedQuote    VendorQuote? @relation(fields: [projectId, selectedQuoteId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  selectedQuoteId  String?
  selectedVendorId String?
  reason           String?
  justification    String? // required when the selection is not the lowest landed total
  createdAt        DateTime     @default(now())
  createdBy        User         @relation("comparisonsCreated", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById      String
  approvedById     String?
  approvedAt       DateTime?

  @@unique([projectId, rfqId]) // one comparison per RFQ
  @@unique([projectId, id])
  // F4-r2: STATUS joins the provenance key, so a purchase order can only ever reference an
  // APPROVED selection (its comparisonStatus column is CHECK-pinned to 'approved').
  @@unique([projectId, id, selectedVendorId, requisitionId, status], map: "QuoteComparison_provenance_status_key")
}

// §F Task 3 — the PO ROOT: immutable identity (vendor through the §H binding + source
// requisition + comparison provenance). Lifecycle lives on VERSION rows; the root never
// changes (DB append-only trigger, the ActivityRequirementRoot pattern).
model PurchaseOrder {
  id            String        @id @default(cuid())
  projectId     String
  project       Project       @relation("purchaseOrderProject", fields: [projectId], references: [id])
  binding       ProjectVendor @relation(fields: [projectId, vendorId], references: [projectId, vendorId], onDelete: NoAction, onUpdate: NoAction)
  vendorId      String
  requisition   Requisition   @relation(fields: [projectId, requisitionId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  requisitionId String
  comparisonId  String // provenance: the APPROVED comparison this PO executes
  // F4-r2: CHECK-pinned to 'approved' and part of the provenance FK — a PO referencing a
  // draft comparison is unrepresentable at PostgreSQL, not merely refused by the service.
  comparisonStatus String     @default("approved")
  createdAt     DateTime      @default(now())
  createdBy     User          @relation("purchaseOrdersCreated", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById   String

  versions PurchaseOrderVersion[]

  @@unique([projectId, id])
  // F4-r2: the FK target sealing every VERSION's containment to this PO's requisition
  @@unique([projectId, id, requisitionId])
}

// §F — ONE version of a PO. draft → issued → partially_received → completed;
// issued → amended (a NEW version row is issued; THIS row's frozen snapshot is retained
// verbatim) | cancelled (only with zero accepted receipts — otherwise close-short with
// reason). Reissue = the new version referencing the amended one via supersedesVersion.
// DB triggers freeze everything except the lifecycle columns; rows are never deleted.
model PurchaseOrderVersion {
  id                String        @id @default(cuid())
  projectId         String
  po                PurchaseOrder @relation(fields: [projectId, poId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  poId              String
  version           Int
  // F4-r2: the PO root's requisition, denormalized (frozen by the lifecycle trigger) and
  // FK-sealed to the root, so every LINE can be containment-sealed in turn.
  requisitionId     String
  status            String        @default("draft") // draft|issued|partially_received|completed|amended|cancelled|closed_short
  supersedesVersion Int? // the amended prior version this reissue replaces
  issuedById        String? // transition attribution (Decision.approvedById precedent)
  issuedAt          DateTime?
  amendedAt         DateTime?
  amendReason       String?
  cancelledAt       DateTime?
  cancelReason      String?
  closedShortAt     DateTime?
  closeShortReason  String?
  createdAt         DateTime      @default(now())
  createdBy         User          @relation("poVersionsCreated", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById       String

  lines PurchaseOrderLine[]

  @@unique([poId, version])
  @@unique([projectId, id])
  // F4-r2: the FK target sealing every LINE's containment to this version's requisition
  @@unique([projectId, id, requisitionId])
}

// §F — a PO line's FROZEN commercial snapshot, copied from the comparison-approved quote
// line at creation. F2 correction — the purchase-UOM triple is EXPLICIT and dimensionally
// sound: the caller orders `purchaseQty` in `purchaseUom`; `conversionToBase` converts one
// purchase unit to base units; `qty` is the DERIVED base quantity = purchaseQty ×
// conversionToBase (DB CHECK), and every §F allocation bound uses it. `rate` is the quote's
// per-BASE-unit rate, so committedAmountBase = rate × purchaseQty × conversionToBase +
// taxAmount + freightAmount ( = rate × qty + tax + freight) is exact. For a PARTIAL order,
// taxAmount/freightAmount carry the ordered share of the quote line's amounts, prorated by
// base quantity and rounded to 2 dp (documented Stage-1 treatment). A DB trigger rejects
// any UPDATE except receivedQty (the procurement-owned received-progress fact Task-4
// receipts append through the participant) and the issuance-time approvedOverage(+reason);
// rows are never deleted. approvedOverage is the ONLY §F bound-3 headroom: set by pmc at
// issuance/amendment with a reason, never afterwards. The (requisitionLineId,
// requirementId, revision) pin is FK-sealed to the requisition line's own pin (F4).
model PurchaseOrderLine {
  id                  String               @id @default(cuid())
  projectId           String
  poVersion           PurchaseOrderVersion @relation(fields: [projectId, poVersionId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  poVersionId         String
  requisitionLine     RequisitionLine      @relation(fields: [projectId, requisitionLineId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  requisitionLineId   String
  // F4-r2: containment — this line's requisition, FK-sealed BOTH to the parent version's
  // requisition and to the requisition line's own requisition (a foreign line is
  // unrepresentable; the frozen trigger covers it).
  requisitionId       String
  requirementId       String // frozen requirement pin (FK-sealed to the requisition line's pin)
  revision            Int
  specFingerprint     String // the DEMANDED material identity — always present (material-only pipeline; selection is match-only)
  quotedMake          String?
  uom                 String // the revision's base UOM (single source)
  purchaseUom         String // the vendor's pack/purchase unit label (defaults to the base UOM)
  purchaseQty         Decimal              @db.Decimal(18, 6) // ordered quantity in purchase units (caller-authored)
  conversionToBase    Decimal              @default(1) @db.Decimal(18, 6) // one purchase unit in base units, frozen at creation
  qty                 Decimal              @db.Decimal(18, 6) // DERIVED base quantity = purchaseQty × conversionToBase (DB CHECK)
  rate                Decimal              @db.Decimal(18, 2)
  taxAmount           Decimal              @db.Decimal(18, 2)
  freightAmount       Decimal              @db.Decimal(18, 2)
  landedAmount        Decimal              @db.Decimal(18, 2) // the quote line's landed metric, copied verbatim
  committedAmountBase Decimal              @db.Decimal(18, 2)
  approvedOverage     Decimal              @default(0) @db.Decimal(18, 6)
  overageReason       String?
  receivedQty         Decimal              @default(0) @db.Decimal(18, 6)

  commitments DeliveryCommitment[]
  // Phase 3 Task 4 — received batches + receipt ledger rows against this line
  stockLots         StockLot[]
  stockTransactions StockTransaction[]

  @@unique([projectId, id])
  @@index([projectId, requisitionLineId])
}

// §F — a vendor's delivery commitment on a PO line: committed → revised* → fulfilled |
// defaulted. Every revision APPENDS a dated promise row — full history, nothing
// overwritten; the LATEST promise drives §A at-risk (Task 6).
model DeliveryCommitment {
  id          String            @id @default(cuid())
  projectId   String
  poLine      PurchaseOrderLine @relation(fields: [projectId, poLineId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  poLineId    String
  status      String            @default("committed") // committed|revised|fulfilled|defaulted
  createdAt   DateTime          @default(now())
  createdBy   User              @relation("commitmentsCreated", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById String
  fulfilledAt DateTime?
  defaultedAt DateTime?

  promises DeliveryPromise[]
  // Phase 3 Task 4 — received batches + receipt ledger rows fulfilling this commitment
  stockLots         StockLot[]
  stockTransactions StockTransaction[]

  @@unique([projectId, id])
}

// §F — ONE dated promise in a commitment's append-only history (PG BEFORE UPDATE/DELETE
// trigger). seq is monotone per commitment; the initial promise carries no reason.
model DeliveryPromise {
  id           String             @id @default(cuid())
  projectId    String
  commitment   DeliveryCommitment @relation(fields: [projectId, commitmentId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  commitmentId String
  seq          Int
  promisedDate DateTime           @db.Date
  reason       String? // why the promise moved (required for every revision; null on the initial promise)
  recordedAt   DateTime           @default(now())
  recordedBy   User               @relation("promisesRecorded", fields: [recordedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  recordedById String

  @@unique([commitmentId, seq])
  @@unique([projectId, id])
}

// ─── Phase 3 Task 4 — the inventory module (plan §C) ───────────────────────────────────────
// A StockLot is ONE immutable received batch (a BEFORE UPDATE OR DELETE trigger blocks every
// change). It carries the full §B MaterialSpecificationRef — technical identity + decision
// provenance — FROZEN at receipt from the pinned requirement revision the received PO line
// executes (selection is match-only, so compliant receipts carry the demanded identity), plus
// provenance FKs to the PO line and the delivery commitment the receipt fulfilled. The lot has
// NO quantity and NO location column: physical truth lives ONLY in the append-only ledger
// below, keyed (projectId, storeLocation, stockLotId).
model StockLot {
  id        String  @id @default(cuid())
  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  poLine       PurchaseOrderLine  @relation(fields: [projectId, poLineId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  poLineId     String
  commitment   DeliveryCommitment @relation(fields: [projectId, commitmentId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  commitmentId String

  // the PO line's frozen requirement pin, FK-sealed so the §B ref below provably belongs to it
  requirement   ActivityRequirement @relation(fields: [projectId, requirementId, revision], references: [projectId, requirementId, revision], onDelete: NoAction, onUpdate: NoAction)
  requirementId String
  revision      Int

  // §B MaterialSpecificationRef — technical identity, verbatim from the revision's spec
  materialCategory     String
  make                 String
  grade                String
  normalizedAttributes String
  baseUom              String
  specFingerprint      String
  // §B provenance (all null = manual spec) — copied from the revision's spec at receipt
  decisionId      String?
  decisionVersion Int?
  optionKey       String?

  receivedAt   DateTime @default(now())
  receivedBy   User     @relation("stockLotsReceived", fields: [receivedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  receivedById String

  transactions StockTransaction[]
  issues       MaterialIssue[]

  @@unique([projectId, id])
  @@index([projectId, specFingerprint])
  @@index([projectId, poLineId])
}

// The §C append-only stock ledger — the ONLY place a quantity moves; NO current-quantity
// column exists anywhere. Every row moves `qty` (base UOM, > 0) from `fromBucket` to
// `toBucket` (null = outside the store), so buckets derive by ONE generic fold per stock key.
// Database CHECKs pin the per-type movement (a receipt row that fills anything but quarantine
// is unrepresentable); a BEFORE UPDATE OR DELETE trigger makes rows immutable; a reversal
// trigger proves each reversal row is the exact inverse of the row it references (§C rule
// iii). `sourceCommandId` records the CommandExecution ledger row that appended the row (§C
// rule ii — a replayed command re-runs nothing, so it appends nothing).
model StockTransaction {
  id            String   @id @default(cuid())
  project       Project  @relation(fields: [projectId], references: [id])
  projectId     String
  lot           StockLot @relation(fields: [projectId, lotId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  lotId         String
  storeLocation String
  type          String // receipt|acceptance|rejection|vendor_return|adjustment|reversal (Task-4 vocabulary; CHECK)
  qty           Decimal  @db.Decimal(18, 6)
  fromBucket    String? // quarantine|acceptedOnHand|rejected (CHECK); null = from outside the store
  toBucket      String? // same domain; null = leaves the store

  // receipt provenance (CHECK: exactly the receipt rows carry both)
  poLine       PurchaseOrderLine?  @relation(fields: [projectId, poLineId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  poLineId     String?
  commitment   DeliveryCommitment? @relation(fields: [projectId, commitmentId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  commitmentId String?

  // Task 5 — activity linkage (CHECK: exactly the reservation/release/issue/consumption/
  // site-return/wastage rows carry it; reversals copy their target's, trigger-verified)
  activity   Activity? @relation(fields: [projectId, activityId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  activityId String?
  // Task 5 — the §E MaterialIssue this row belongs to: the issue row itself plus every
  // custody movement (consumption/site-return/wastage) recorded AGAINST it
  issue   MaterialIssue? @relation(fields: [projectId, issueId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  issueId String?
  // Task 5 — a transfer's DESTINATION stock key (CHECK: exactly the transfer rows carry it);
  // the row's own storeLocation is the source, so ONE row moves acceptedOnHand between keys
  toStoreLocation String?

  // reversal linkage (CHECK: exactly the reversal rows carry it; partial unique — once each)
  reversedTx   StockTransaction?  @relation("stockReversal", fields: [projectId, reversedTxId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  reversedTxId String?
  reversedBy   StockTransaction[] @relation("stockReversal")

  // quality decision facts (CHECK: acceptance carries result + evidence; rejection evidence)
  qualityResult   String?
  evidenceMedia   Media?  @relation(fields: [projectId, evidenceMediaId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  evidenceMediaId String?
  reason          String? // required on adjustment + reversal (CHECK)

  // Tasks 4–5 integrity correction (F1) — every ledger row cites the CommandExecution that
  // appended it (§C rule ii): REQUIRED (a server one-shot command backs even an unkeyed call)
  // and project-contained by the composite FK (a cross-project source command is unrepresentable).
  sourceCommand   CommandExecution @relation(fields: [projectId, sourceCommandId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  sourceCommandId String
  recordedAt      DateTime          @default(now())
  recordedBy      User              @relation("stockTransactionsRecorded", fields: [recordedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  recordedById    String

  @@unique([projectId, id])
  @@index([projectId, lotId, storeLocation])
  @@index([projectId, poLineId])
  @@index([projectId, activityId])
  @@index([projectId, issueId])
}

// Task 5 — the §E-CANONICAL record of material that LEFT THE STORE for an activity ("an
// issue is not a delivery"). Immutable (BEFORE UPDATE OR DELETE trigger): corrections
// reverse the underlying ledger rows (§C rule iii), never edit or delete this record, so a
// daily-log reference to an issue id can never be orphaned. The Daily Log screen reads
// these through inventory's `stock.issues` query — nothing is copied into SiteMaterial.
model MaterialIssue {
  id        String  @id @default(cuid())
  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  lot           StockLot @relation(fields: [projectId, lotId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  lotId         String
  storeLocation String // the §C stock key the material left
  activity      Activity @relation(fields: [projectId, activityId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  activityId    String
  qty           Decimal  @db.Decimal(18, 6) // base UOM

  issuedAt   DateTime @default(now())
  issuedBy   User     @relation("materialIssuesIssued", fields: [issuedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  issuedById String

  transactions StockTransaction[]

  @@unique([projectId, id])
  @@index([projectId, activityId])
  @@index([projectId, lotId])
}

model Decision {
  id             String           @id // e.g. "DL-014"
  project        Project          @relation(fields: [projectId], references: [id])
  projectId      String
  title          String
  room           String // display fallback / legacy; the node path is authoritative when nodeId is set
  node           ProjectNode?     @relation(fields: [projectId, nodeId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  nodeId         String?
  status         DecisionStatus   @default(pending)
  ageDays        Int?
  photoSwatch    String
  approvedOption String?
  material       String?
  approver       String? // human-readable approver line (the caller's REAL name since Phase 1 Task 2)
  approvedById   String? // the approving user's id — real attribution (Phase 1 Task 2)
  onBehalfOf     String? // 'client' when a PMC approves on the client's behalf — never disguised
  date           String? // display date, e.g. "12 Jun 2026"
  cost           Int? // rupees
  createdAt      DateTime         @default(now())
  // Draft → Publish lifecycle. While `publishedAt` is null the decision is a private
  // DRAFT: the snapshot delivers it only to its author (`authorId`), it never notifies
  // the client, and the app treats it as weightless (no pending count, no gate). Publish
  // sets `publishedAt` and fires the normal side-effects. Both nullable/additive so the
  // migration is safe on the live DB; existing rows (published) are backfilled to createdAt.
  publishedAt    DateTime?
  authorId       String?

  options           DecisionOption[]
  events            DecisionEvent[]
  approvalRevisions DecisionApprovalRevision[]
  materialSpecs     MaterialRequirementSpec[]
  labourSpecs       LabourRequirementSpec[] // Phase 4 Task 1 — labour demand provenance
  changeRequests ChangeRequest[]
  activities     Activity[]
  materials      SiteMaterial[]
  media          Media[]
  drawings       Drawing[]

  // composite identity so referencing models can carry (projectId, decisionId)
  // foreign keys — the DB itself rejects a cross-project link (Phase 0 Task 5)
  @@unique([projectId, id])
  // pre-existing in the DB since 20260715000000_add_location_tree; declared here so
  // the schema matches the database exactly (drift found by `prisma migrate diff`)
  @@index([nodeId])
}

model DecisionOption {
  id          String   @id @default(cuid())
  decision    Decision @relation(fields: [decisionId], references: [id])
  decisionId  String
  label       String
  optionKey   String
  material    String
  delta       Int // rupees
  swatch      String
  photoUrl    String? // uploaded sample photo (media url); swatch is the fallback
  recommended Boolean  @default(false)
  order       Int      @default(0)

  approvalRevisions DecisionApprovalRevision[]

  // the approval register (and requirement provenance behind it) pins an option by
  // (decisionId, optionKey) — the pair is a database-enforced candidate key
  @@unique([decisionId, optionKey])
}

// The IMMUTABLE approval register of a decision (Phase 3 Task 1 correction round 2, finding 1).
// One row PER approval/reapproval, created in the SAME transaction as the approve command.
// Rows are database-immutable (BEFORE UPDATE OR DELETE trigger); `version` is monotonic per
// decision INCLUDING unprovable legacy history — the service allocates
// max(head revision, recorded approval events) + 1, so a legacy approval's first reapproval is
// version 2, never a colliding version 1. Requirement provenance (MaterialRequirementSpec) FKs
// onto (projectId, decisionId, version, optionKey): a spec can only ever reference an approval
// that REALLY happened, for an option the decision REALLY has. `decisions.approvedRef` serves
// provenance from the head row alone — never from event counts or label matching.
model DecisionApprovalRevision {
  id           String         @id
  projectId    String
  decision     Decision       @relation(fields: [projectId, decisionId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  decisionId   String
  version      Int
  option       DecisionOption @relation(fields: [decisionId, optionKey], references: [decisionId, optionKey], onDelete: NoAction, onUpdate: NoAction)
  optionKey    String
  approvedAt   DateTime
  approvedBy   User?          @relation("approvalRevisionsApproved", fields: [approvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approvedById String? // null only on backfilled legacy rows whose approver was never recorded
  onBehalfOf   String? // 'client' when a PMC recorded the client's consent — never disguised

  materialSpecs MaterialRequirementSpec[]
  labourSpecs   LabourRequirementSpec[] // Phase 4 Task 1 — labour demand provenance (same register)

  @@unique([decisionId, version])
  // the provenance FK target: version AND option bind together to one immutable approval fact
  // (explicit name — the generated one exceeds PostgreSQL's 63-char identifier limit)
  @@unique([projectId, decisionId, version, optionKey], map: "DecisionApprovalRevision_provenance_target_key")
}

// Append-only lifecycle + audit log for a decision.
model DecisionEvent {
  id         String   @id @default(cuid())
  decision   Decision @relation(fields: [decisionId], references: [id])
  decisionId String
  type       String // drafted | issued | approved | reapproved | change_requested | change_withdrawn
  actor      String // legacy display label; actorName is authoritative on new rows
  actorId    String? // real user identity (Phase 1 Task 2); null on pre-Phase-1 rows
  actorName  String?
  actorRole  String? // the role HELD AT ACTION TIME (gate finding 6) — a later role change never rewrites history
  at         DateTime @default(now())
  payload    Json?
}

// One reopening of a locked decision. Status machine: 'open' -> 'resolved' (by
// client re-approval) | 'withdrawn' (by the requester or PMC). EXACTLY ONE open
// request per decision is enforced by a partial unique index —
// "ChangeRequest_one_open_per_decision" ON ("decisionId") WHERE status = 'open'
// (raw SQL in 20260910000000_phase1_change_control; not expressible in Prisma).
// Legacy rows were backfilled: 'pending' -> 'open' only while their decision was
// still reopened, else 'resolved' with a null resolution.
model ChangeRequest {
  id             String    @id @default(cuid())
  decision       Decision  @relation(fields: [decisionId], references: [id])
  decisionId     String
  reason         String
  costImpact     Int // rupees
  timeImpactDays Int
  status         String    @default("open")
  requestedById  String? // real requester identity; null on pre-Phase-1 rows
  resolvedById   String?
  resolvedAt     DateTime?
  resolution     String? // 'reapproved' | 'withdrawn'; null on backfilled legacy rows
  createdAt      DateTime  @default(now())
}

model Activity {
  id             String         @id // e.g. "ACT-31"
  project        Project        @relation(fields: [projectId], references: [id])
  projectId      String
  name           String
  zone           String
  status         ActivityStatus @default(not_started)
  // planned/actual as day-offsets from 1 Jun 2026 (LEGACY prototype timeline model —
  // kept for compatibility; the civil dates below are canonical going forward)
  plannedStart   Int
  plannedEnd     Int
  actualStart    Int?
  actualEnd      Int?
  // Real civil dates (Phase 0 Task 6); display strings are derived, never compared
  plannedStartDate DateTime? @db.Date
  plannedEndDate   DateTime? @db.Date
  actualStartDate  DateTime? @db.Date
  actualEndDate    DateTime? @db.Date
  // Phase 1 Task 5 — the sign-off civil day (set ONLY by closing-inspection
  // approval); actualEndDate above remains the CLAIMED work-end day
  doneAt           DateTime? @db.Date
  // The completion CLAIM: who said the work was finished (an attributable,
  // membership-validated fact — the reject path assigns corrective work from it).
  // Composite FK to Membership — a claimant without a membership on THIS
  // project is impossible even on a direct write (memberships are soft-removed).
  completionRequestedBy     Membership? @relation("CompletionClaims", fields: [projectId, completionRequestedById], references: [projectId, userId], onDelete: NoAction, onUpdate: NoAction)
  completionRequestedById   String?
  completionRequestedByName String?
  completionRequestedAt     DateTime?
  block          String?
  // stored readiness gates; the Decision gate is derived live from the decision
  gateMaterial   GateState @default(na)
  gateTeam       GateState @default(na)
  gateInspection GateState @default(na)
  decision       Decision?      @relation(fields: [projectId, decisionId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  decisionId     String?
  phase          Phase?         @relation(fields: [projectId, phaseId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  phaseId        String?
  // Location spine: where this work happens (zone/room/object). NodesService unlinks
  // on node delete; the composite FK forbids a cross-project filing at the database.
  node           ProjectNode?   @relation(fields: [projectId, nodeId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  nodeId         String?
  order          Int            @default(0)
  drawings       Drawing[]
  // Phase 3 Task 5 — stock movements scoped to this activity + the §E issue records
  stockTransactions StockTransaction[]
  materialIssues    MaterialIssue[]
  // inspections whose requirement edge names this activity (Phase 1 Task 4)
  inspections    Inspection[]
  // manual readiness exceptions — attributable, evidenced, EXPIRING (Phase 1 Task 6)
  gateOverrides  GateOverride[]

  @@unique([projectId, id])
  @@index([nodeId])
  requirements ActivityRequirement[]
}

// A manual readiness exception (Phase 1 Task 6): the PMC overrides ONE gate's
// derived value with an attributable, reasoned, optionally evidenced record that
// ALWAYS expires — expiry (or early revocation) restores the derivation. No
// silent flag-flips: every override is audited and serialized in the snapshot.
model GateOverride {
  id         String    @id @default(cuid())
  project    Project   @relation(fields: [projectId], references: [id])
  projectId  String
  // composite FK — an override can only name THIS project's activity
  activity   Activity  @relation(fields: [projectId, activityId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  activityId String
  gate       String // decision | material | team | inspection | drawing
  state      GateState
  reason     String
  actorId    String
  actorName  String
  // optional supporting photo — composite FK, same-project by construction (Task 4 key)
  evidence        Media?  @relation(fields: [projectId, evidenceMediaId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  evidenceMediaId String?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  @@index([projectId, activityId])
}

// A project phase (Foundation → Structure → MEP → Finishing…). Groups activities
// for phase-level monitoring; planned window as day-offsets (like activities).
model Phase {
  id           String     @id @default(cuid())
  project      Project    @relation(fields: [projectId], references: [id])
  projectId    String
  name         String
  order        Int        @default(0)
  plannedStart Int        @default(0) // LEGACY day-offset (kept for compatibility)
  plannedEnd   Int        @default(0) // LEGACY day-offset (kept for compatibility)
  // Real civil dates (Phase 0 Task 6)
  plannedStartDate DateTime? @db.Date
  plannedEndDate   DateTime? @db.Date
  activities   Activity[]

  // composite identity for the (projectId, phaseId) FK on Activity
  @@unique([projectId, id])
  @@index([projectId])
}

model Inspection {
  id        String           @id // e.g. "INSP-22"
  project   Project          @relation(fields: [projectId], references: [id])
  projectId String
  kind      String // "checklist" (engineer draft) | "review" (submitted to PMC)
  title     String
  zone      String
  by        String?
  date      String // LEGACY display string (derived; never sorted or compared)
  inspectionDate DateTime? @db.Date // real civil date (Phase 0 Task 6)
  submitted Boolean          @default(false)
  decided   Boolean          @default(false)
  // Phase 1 Task 5: the UNAMBIGUOUS closing-sign-off marker (id-pattern matching
  // retired). Approving a closing inspection is what completes its activity.
  closing   Boolean          @default(false)
  // The REQUIREMENT EDGE (Phase 1 Task 4): the Activity this inspection accepts.
  // Composite FK — a cross-project edge is impossible even on a direct write.
  activity   Activity? @relation(fields: [projectId, activityId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  activityId String?
  // Phase 2 Task 10 (Module 3) correction — the INSPECTION-OWNED activity label. A closing inspection's
  // serialized `activityName` was formerly read live off `Activity.name` (a cross-module read the projection
  // could not observe). It is now stored here: set when the closing inspection is created, updated by the
  // inspections participant when the activity is renamed (both append an inspection event), and backfilled
  // from the linked Activity in the correction migration. Null for inspections with no linked activity.
  activityName String?
  // A reinspection names its predecessor and inherits its activityId. AT MOST ONE
  // direct child per rejected inspection — partial unique index
  // "Inspection_one_reinspection_child" ON ("reinspectionOfId") WHERE NOT NULL
  // (raw SQL in 20260930000000_phase1_inspection_evidence).
  reinspectionOf   Inspection?  @relation("Reinspection", fields: [projectId, reinspectionOfId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  reinspectionOfId String?
  reinspections    Inspection[] @relation("Reinspection")
  // WHO must correct the work: an ACTIVE engineer/contractor member (service-validated;
  // the Membership FK is the backstop — memberships are soft-removed, never deleted).
  assignee   Membership? @relation(fields: [projectId, assigneeId], references: [projectId, userId], onDelete: NoAction, onUpdate: NoAction)
  assigneeId String?
  dueDate    DateTime? @db.Date // real civil due date (decide-day + N days, PMC-overridable)
  // attribution (Phase 1 global rule): who submitted / decided
  submittedById   String?
  submittedByName String?
  decidedById     String?
  decidedByName   String?
  // Location spine: where this quality check happens. NodesService unlinks on node
  // delete; the composite FK forbids a cross-project filing at the database.
  node      ProjectNode?     @relation(fields: [projectId, nodeId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  nodeId    String?
  items     InspectionItem[]
  media     Media[]

  @@unique([projectId, id]) // composite identity — tenant-safe reference target (Task 4)
  @@index([nodeId])
}

model InspectionItem {
  id           String            @id @default(cuid())
  inspection   Inspection        @relation(fields: [inspectionId], references: [id])
  inspectionId String
  name         String
  order        Int               @default(0)
  // checklist fields
  state        String? // pass | fail | na
  // DEPRECATED display derivative (Task 4): real evidence is the LINKED Media rows;
  // this counter is never proof and never validated against.
  photos       Int               @default(0)
  note         String            @default("")
  // review fields
  result       InspectionResult?
  swatch       String?
  rejected     Boolean           @default(false)
  media        Media[]

  @@unique([inspectionId, id]) // containment identity for the Media chain (Task 4)
}

model DailyLog {
  id          String         @id @default(cuid())
  project     Project        @relation(fields: [projectId], references: [id])
  projectId   String
  date        String // LEGACY display string (derived; never sorted or compared)
  // The civil day the site work belongs to (Phase 0 Task 6) — "latest log" orders by
  // THIS first; createdAt (the immutable creation instant) is only the tie-breaker.
  logDate     DateTime?      @db.Date
  createdAt   DateTime       @default(now())
  checkedIn   Boolean        @default(false)
  checkinTime String?
  submitted   Boolean        @default(false)
  progress    Int            @default(0)
  crew        CrewRow[]
  materials   SiteMaterial[]
  media       Media[]

  // composite identity for (projectId, dailyLogId) FKs — see Media
  @@unique([projectId, id])
}

model CrewRow {
  id         String   @id @default(cuid())
  dailyLog   DailyLog @relation(fields: [dailyLogId], references: [id])
  dailyLogId String
  trade      String
  count      Int      @default(0)
  order      Int      @default(0)
}

model SiteMaterial {
  id         String    @id @default(cuid())
  // Canonical project ownership (Codex gate finding 4): a material belongs to ONE
  // project directly — the composite FKs below then make every reference (its log,
  // the approving decision, the staging place) provably same-project in PostgreSQL.
  project    Project   @relation(fields: [projectId], references: [id])
  projectId  String
  dailyLog   DailyLog  @relation(fields: [projectId, dailyLogId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  dailyLogId String
  decision   Decision? @relation(fields: [projectId, decisionId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  decisionId String?
  name       String
  qty        String
  zone       String
  matched    Boolean   @default(true)
  swatch     String
  photo      Boolean   @default(false)
  // Location spine: where this material was delivered / is staged. NodesService
  // unlinks on node delete; the composite FK forbids a cross-project filing.
  node       ProjectNode? @relation(fields: [projectId, nodeId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  nodeId     String?
  order      Int       @default(0)

  // Phase 3 Task 5 (§E) — the explicit resolution closing this observation (at most one)
  resolution MismatchResolution?

  // referenced identity for the resolution's composite (projectId, siteMaterialId) FK (Task 5)
  @@unique([projectId, id])
  @@index([nodeId])
  @@index([projectId])
}

// Phase 3 Task 5 (§E) — an explicit, audited resolution closing EXACTLY ONE `matched: false`
// observation. The observation row is NEVER edited (it stays `matched: false` as history);
// `siteMaterialId` is UNIQUE here, so a second resolution of the same observation is
// unrepresentable. Immutable (BEFORE UPDATE OR DELETE trigger). The activity's mismatch
// block clears ONLY when no unresolved mismatch observation remains for its decision.
model MismatchResolution {
  id        String  @id @default(cuid())
  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  siteMaterial   SiteMaterial @relation(fields: [projectId, siteMaterialId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  siteMaterialId String

  resolution String // the disposition, e.g. 'returned-and-replaced'
  reason     String // why this disposition closes the dispute

  resolvedAt   DateTime @default(now())
  resolvedBy   User     @relation("mismatchesResolved", fields: [resolvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  resolvedById String

  @@unique([projectId, siteMaterialId])
  @@unique([projectId, id])
}

model Notification {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id])
  projectId String
  text      String
  color     String
  time      String // relative label, e.g. "2h ago" / "just now"
  at        DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  projectId String?
  actor     String // legacy display label (role string on pre-Phase-1 rows)
  actorId   String? // real user identity (Phase 1 Task 2); populated going forward
  actorRole String? // the role HELD AT ACTION TIME (gate finding 6)
  action    String
  entity    String
  entityId  String
  at        DateTime @default(now())
  payload   Json?
}

// ── Phase 4 Task 1 — Labour readiness foundation (plan §§B/D/H) ──────────────────────────────
// The labour LEAF module (plan §G, round-3: dependsOn = []). All rows are project-contained; a
// cross-project reference is unrepresentable in PostgreSQL (same-project composite FKs). Every
// Prisma-inexpressible seal — the labour-aware type↔detail correspondence, the labour-spec/slice
// append-only triggers, the demand CHECKs, and the one-active-crew-membership partial unique —
// is added in raw SQL by 20270110000000_phase4_t1_labour.

// Project-contained labour TRADE catalog. A worker's trade and a labour requirement's trade
// reference an entry here by composite (projectId, code) FK, so a code always resolves to a
// real same-project catalog row.
model LabourTrade {
  project     Project  @relation(fields: [projectId], references: [id])
  projectId   String
  code        String
  name        String
  createdAt   DateTime @default(now())
  createdBy   User     @relation("labourTradesCreated", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById String

  workers     Worker[]
  labourSpecs LabourRequirementSpec[]

  @@id([projectId, code])
}

// Project-contained labour SKILL catalog. A worker's skillCodes and a labour requirement's
// optional skillCode are validated in-service against this catalog.
model LabourSkill {
  project     Project  @relation(fields: [projectId], references: [id])
  projectId   String
  code        String
  name        String
  createdAt   DateTime @default(now())
  createdBy   User     @relation("labourSkillsCreated", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById String

  labourSpecs LabourRequirementSpec[]

  @@id([projectId, code])
}

// A trusted, project-contained WORKER identity (§H) — the atomic capacity source (round-1).
// activeFrom/activeTo bound the engagement; a revoke stamps revokedAt+revokedById.
model Worker {
  id          String    @id @default(cuid())
  project     Project   @relation(fields: [projectId], references: [id])
  projectId   String
  name        String
  // the worker's primary trade — a same-project catalog entry (composite FK)
  trade       LabourTrade @relation(fields: [projectId, tradeCode], references: [projectId, code], onDelete: NoAction, onUpdate: NoAction)
  tradeCode   String
  // additional skills — a text array validated in-service against the LabourSkill catalog (an
  // array cannot carry a referential FK; membership is service-enforced + covered by tests)
  skillCodes  String[]
  activeFrom  DateTime  @db.Date
  activeTo    DateTime? @db.Date
  revokedAt   DateTime?
  revokedBy   User?     @relation("workersRevoked", fields: [revokedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  revokedById String?
  createdAt   DateTime  @default(now())
  createdBy   User      @relation("workersOnboarded", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById String

  devices         WorkerDevice[]
  crewMemberships CrewMembership[]
  ledBy           Crew[]           @relation("crewIncharge")

  // composite identity for same-project (projectId, workerId) FKs (WorkerDevice, Crew, membership)
  @@unique([projectId, id])
  @@index([projectId, tradeCode])
}

// A named set of workers under an in-charge (mistri) — ORGANIZATIONAL only, NOT an atomic
// capacity source (round-2 finding 1; the atomic source is the Worker).
model Crew {
  id               String    @id @default(cuid())
  project          Project   @relation(fields: [projectId], references: [id])
  projectId        String
  name             String
  // the in-charge (mistri) — a same-project worker (composite FK); optional
  incharge         Worker?   @relation("crewIncharge", fields: [projectId, inchargeWorkerId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  inchargeWorkerId String?
  activeFrom       DateTime  @db.Date
  activeTo         DateTime? @db.Date
  revokedAt        DateTime?
  revokedBy        User?     @relation("crewsRevoked", fields: [revokedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  revokedById      String?
  createdAt        DateTime  @default(now())
  createdBy        User      @relation("crewsFormed", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById      String

  members CrewMembership[]

  @@unique([projectId, id])
}

// One worker's membership in a crew — project-contained (both composite FKs carry projectId, so
// a membership can NEVER cross-link a worker and crew from different projects). A member is
// removed by stamping removedAt (organizational history preserved). A partial-unique index (raw
// SQL) enforces at most one ACTIVE membership per (crew, worker).
model CrewMembership {
  id          String    @id @default(cuid())
  project     Project   @relation(fields: [projectId], references: [id])
  projectId   String
  crew        Crew      @relation(fields: [projectId, crewId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  crewId      String
  worker      Worker    @relation(fields: [projectId, workerId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  workerId    String
  addedAt     DateTime  @default(now())
  addedBy     User      @relation("crewMembersAdded", fields: [addedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  addedById   String
  removedAt   DateTime?
  removedBy   User?     @relation("crewMembersRemoved", fields: [removedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  removedById String?

  @@index([projectId, crewId])
  @@index([projectId, workerId])
}

// The LABOUR-ONLY specification detail of one requirement revision (§B) — the sibling of
// MaterialRequirementSpec. Labour-module-owned; written through LabourParticipant.writeRequirementSpec
// inside the Activities requirement command (the cycle-exempt participant channel, §G). The
// fingerprint hashes ONLY (tradeCode, skillCode, shift); decision provenance is stored, not
// hashed. Append-only via the shared BEFORE UPDATE OR DELETE trigger; a labour-aware DB
// type↔detail trigger enforces exactly-one detail per revision (material XOR labour). The demand
// is carried as explicit per-civilDate LabourDemandSlice rows (all sharing this spec's shift).
model LabourRequirementSpec {
  id            String              @id @default(cuid())
  project       Project             @relation(fields: [projectId], references: [id])
  projectId     String
  requirement   ActivityRequirement @relation(fields: [projectId, requirementId, revision], references: [projectId, requirementId, revision], onDelete: NoAction, onUpdate: NoAction)
  requirementId String
  revision      Int

  trade                 LabourTrade @relation(fields: [projectId, tradeCode], references: [projectId, code], onDelete: NoAction, onUpdate: NoAction)
  tradeCode             String
  // optional; a bare-trade demand. Task-1 correction F3 — a same-project composite FK makes a
  // nonexistent OR cross-project skill unrepresentable in PostgreSQL (was service-validated only).
  skill                 LabourSkill? @relation(fields: [projectId, skillCode], references: [projectId, code], onDelete: NoAction, onUpdate: NoAction)
  skillCode             String?
  shift                 String // 'day' | 'night' — part of the fingerprinted identity
  labourSpecFingerprint String

  // AUTHORITATIVE decision provenance — all null (manual) or all server-resolved (CHECK), FK-bound
  // onto the immutable DecisionApprovalRevision register (same rule as MaterialRequirementSpec).
  decision         Decision?                 @relation(fields: [projectId, decisionId], references: [projectId, id], onDelete: NoAction, onUpdate: NoAction)
  decisionId       String?
  approvalRevision DecisionApprovalRevision? @relation(fields: [projectId, decisionId, decisionVersion, optionKey], references: [projectId, decisionId, version, optionKey], onDelete: NoAction, onUpdate: NoAction)
  decisionVersion  Int?
  optionKey        String?

  @@unique([projectId, requirementId, revision])
  @@index([projectId, labourSpecFingerprint])
}

// One explicit (civilDate, shift, personShiftQty) demand slice of a labour requirement revision
// (§B, round-2 finding 2). shift is the parent spec's shift (joined for the DTO); personShiftQty
// is a positive integer count of person-shifts (a CHECK). A partial-unique (raw SQL) enforces one
// slice per (requirement, revision, civilDate). Append-only via the shared trigger; a raw-SQL
// trigger requires the revision to be labour-typed.
model LabourDemandSlice {
  id             String              @id @default(cuid())
  project        Project             @relation(fields: [projectId], references: [id])
  projectId      String
  requirement    ActivityRequirement @relation(fields: [projectId, requirementId, revision], references: [projectId, requirementId, revision], onDelete: NoAction, onUpdate: NoAction)
  requirementId  String
  revision       Int
  civilDate      DateTime @db.Date
  personShiftQty Int

  @@index([projectId, requirementId, revision])
}
