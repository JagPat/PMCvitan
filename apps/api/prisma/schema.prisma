// Vitan PMC — database schema (PostgreSQL via Prisma).
// Phase-7 Slice 1: the entities behind the project snapshot and the core
// mutations. Fields are aligned with the frontend domain model
// (apps/web / packages/shared) so the API returns shapes the client uses
// directly. Auth (users/OTP/workers), media and offline-outbox tables arrive
// in the next Phase-7 slice. See docs/DATA_MODEL.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DecisionStatus {
  pending
  approved
  change
}

enum ActivityStatus {
  not_started
  in_progress
  done
  blocked
}

enum GateState {
  ok
  wait
  fail
  na
}

enum InspectionResult {
  PASS
  FAIL
}

model Project {
  id           String   @id
  name         String
  short        String
  descriptor   String
  stage        String
  siteCode     String
  projStart    String
  projEnd      String
  elapsedPct   Int
  todayDay     Int
  milestonePct Int
  createdAt    DateTime @default(now())

  decisions     Decision[]
  activities    Activity[]
  inspections   Inspection[]
  dailyLogs     DailyLog[]
  notifications Notification[]
}

model Decision {
  id             String           @id // e.g. "DL-014"
  project        Project          @relation(fields: [projectId], references: [id])
  projectId      String
  title          String
  room           String
  status         DecisionStatus   @default(pending)
  ageDays        Int?
  photoSwatch    String
  approvedOption String?
  material       String?
  approver       String?
  date           String? // display date, e.g. "12 Jun 2026"
  cost           Int? // rupees
  createdAt      DateTime         @default(now())

  options        DecisionOption[]
  events         DecisionEvent[]
  changeRequests ChangeRequest[]
  activities     Activity[]
  materials      SiteMaterial[]
}

model DecisionOption {
  id          String   @id @default(cuid())
  decision    Decision @relation(fields: [decisionId], references: [id])
  decisionId  String
  label       String
  optionKey   String
  material    String
  delta       Int // rupees
  swatch      String
  recommended Boolean  @default(false)
  order       Int      @default(0)
}

// Append-only lifecycle + audit log for a decision.
model DecisionEvent {
  id         String   @id @default(cuid())
  decision   Decision @relation(fields: [decisionId], references: [id])
  decisionId String
  type       String // issued | approved | locked | change_requested
  actor      String
  at         DateTime @default(now())
  payload    Json?
}

model ChangeRequest {
  id             String   @id @default(cuid())
  decision       Decision @relation(fields: [decisionId], references: [id])
  decisionId     String
  reason         String
  costImpact     Int // rupees
  timeImpactDays Int
  status         String   @default("pending")
  createdAt      DateTime @default(now())
}

model Activity {
  id             String         @id // e.g. "ACT-31"
  project        Project        @relation(fields: [projectId], references: [id])
  projectId      String
  name           String
  zone           String
  status         ActivityStatus @default(not_started)
  // planned/actual as day-offsets from 1 Jun 2026 (frontend timeline model)
  plannedStart   Int
  plannedEnd     Int
  actualStart    Int?
  actualEnd      Int?
  block          String?
  // stored readiness gates; the Decision gate is derived live from the decision
  gateMaterial   GateState @default(na)
  gateTeam       GateState @default(na)
  gateInspection GateState @default(na)
  decision       Decision?      @relation(fields: [decisionId], references: [id])
  decisionId     String?
  order          Int            @default(0)

  @@unique([projectId, id])
}

model Inspection {
  id        String           @id // e.g. "INSP-22"
  project   Project          @relation(fields: [projectId], references: [id])
  projectId String
  kind      String // "checklist" (engineer draft) | "review" (submitted to PMC)
  title     String
  zone      String
  by        String?
  date      String
  submitted Boolean          @default(false)
  decided   Boolean          @default(false)
  items     InspectionItem[]
}

model InspectionItem {
  id           String            @id @default(cuid())
  inspection   Inspection        @relation(fields: [inspectionId], references: [id])
  inspectionId String
  name         String
  order        Int               @default(0)
  // checklist fields
  state        String? // pass | fail | na
  photos       Int               @default(0)
  note         String            @default("")
  // review fields
  result       InspectionResult?
  swatch       String?
  rejected     Boolean           @default(false)
}

model DailyLog {
  id          String         @id @default(cuid())
  project     Project        @relation(fields: [projectId], references: [id])
  projectId   String
  date        String
  checkedIn   Boolean        @default(false)
  checkinTime String?
  submitted   Boolean        @default(false)
  progress    Int            @default(0)
  crew        CrewRow[]
  materials   SiteMaterial[]
}

model CrewRow {
  id         String   @id @default(cuid())
  dailyLog   DailyLog @relation(fields: [dailyLogId], references: [id])
  dailyLogId String
  trade      String
  count      Int      @default(0)
  order      Int      @default(0)
}

model SiteMaterial {
  id         String    @id @default(cuid())
  dailyLog   DailyLog  @relation(fields: [dailyLogId], references: [id])
  dailyLogId String
  decision   Decision? @relation(fields: [decisionId], references: [id])
  decisionId String?
  name       String
  qty        String
  zone       String
  matched    Boolean   @default(true)
  swatch     String
  photo      Boolean   @default(false)
  order      Int       @default(0)
}

model Notification {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id])
  projectId String
  text      String
  color     String
  time      String // relative label, e.g. "2h ago" / "just now"
  at        DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  projectId String?
  actor     String
  action    String
  entity    String
  entityId  String
  at        DateTime @default(now())
  payload   Json?
}
