# apps/web build-time environment (Vite inlines these at build). Copy to .env.
# All are OPTIONAL — with none set, the app runs as the seeded local demo.

# Point the app at the deployed API to use real data + auth. Unset = local demo.
VITE_API_URL="https://pms-api.vitan.in"

# Passwordless dev auth (the "Viewing as" persona switcher). SECURE BY DEFAULT:
# the persona switcher + auto dev-connect are OFF unless this is exactly "true",
# and the app is gated behind a real sign-in. Must agree with the API's
# ALLOW_DEV_AUTH. (Ignored — treated as on — when VITE_API_URL is unset, since
# the local demo has no backend to sign in against.)
VITE_ALLOW_DEV_AUTH="true"

# Google sign-in. Set the OAuth Web client ID to render the Google button
# (must match the API's GOOGLE_CLIENT_ID). Blank = the button is hidden.
VITE_GOOGLE_CLIENT_ID=""
